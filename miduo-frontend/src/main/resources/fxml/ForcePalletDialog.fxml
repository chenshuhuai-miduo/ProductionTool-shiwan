<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.miduo.cloud.frontend.controller.ForcePalletDialogController"
      spacing="20" 
      style="-fx-background-color: white; -fx-padding: 24px;">
    
    <!-- 标题 -->
    <Label text="强制满垛确认" styleClass="dialog-title">
        <font>
            <Font name="Microsoft YaHei Bold" size="18"/>
        </font>
    </Label>
    
    <!-- 提示信息区域 -->
    <VBox spacing="16" style="-fx-padding: 16px; -fx-background-color: #fff7e6; -fx-background-radius: 8px; -fx-border-color: #ffa940; -fx-border-width: 1px; -fx-border-radius: 8px;">
        <!-- 警告图标和主提示 -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <StackPane fx:id="mainWarnIconPane" minWidth="24" minHeight="24" prefWidth="24" prefHeight="24"
                       maxWidth="24" maxHeight="24"/>
            <Label fx:id="mainPromptLabel" 
                   text="确定要强制满垛吗？当前垛有 X 箱，将立即形成一垛。" 
                   wrapText="true"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #d46b08;">
                <VBox.margin>
                    <Insets right="12"/>
                </VBox.margin>
            </Label>
        </HBox>
        
        <!-- 详细说明 -->
        <Label fx:id="detailLabel" 
               text="此操作将忽略采集规格要求，以当前箱数作为满垛标准。" 
               wrapText="true"
               style="-fx-font-size: 13px; -fx-text-fill: #ad6800; -fx-padding: 0 0 0 36px;"/>
        
        <!-- 补充信息（动态显示） -->
        <HBox fx:id="supplementRow" spacing="10" alignment="TOP_LEFT" visible="false" managed="false"
              style="-fx-padding: 0 0 0 8px;">
            <StackPane fx:id="supplementWarnIconPane" minWidth="20" minHeight="20" prefWidth="20" prefHeight="20"
                       maxWidth="20" maxHeight="20"/>
            <Label fx:id="supplementLabel"
                   text=""
                   wrapText="true"
                   HBox.hgrow="ALWAYS"
                   style="-fx-font-size: 13px; -fx-text-fill: #ad6800;"/>
        </HBox>
    </VBox>
    
    <!-- 当前垛信息 -->
    <VBox spacing="12" style="-fx-padding: 16px; -fx-background-color: #f5f5f5; -fx-background-radius: 8px;">
        <Label text="当前垛信息" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
        
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="订单编号：" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <Label fx:id="orderNoLabel" text="--" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
        </HBox>
        
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="当前箱数：" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <Label fx:id="currentCountLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1890ff;"/>
            <Label text="箱" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
        </HBox>
        
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="每垛箱数：" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <Label fx:id="boxesPerPalletLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            <Label text="箱" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
        </HBox>
        
        <Separator/>
        
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="箱数差异：" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <Label fx:id="virtualBoxesLabel" text="0" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #ff4d4f;"/>
            <Label text="箱" style="-fx-font-size: 13px; -fx-text-fill: #666666;"/>
            <Label text="（不会生成虚拟箱码）" style="-fx-font-size: 12px; -fx-text-fill: #999999; -fx-padding: 0 0 0 8px;"/>
        </HBox>
    </VBox>
    
    <!-- 按钮区域 -->
    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 12px 0 0 0;">
        <Button fx:id="cancelButton" 
                text="取消" 
                onAction="#onCancel"
                style="-fx-min-width: 100px; -fx-min-height: 36px; -fx-font-size: 14px; -fx-background-color: #f0f0f0; -fx-text-fill: #333333; -fx-cursor: hand;"/>
        
        <Button fx:id="confirmButton" 
                text="确认强制满垛" 
                onAction="#onConfirm"
                style="-fx-min-width: 120px; -fx-min-height: 36px; -fx-font-size: 14px; -fx-background-color: #ff4d4f; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>
    
</VBox>

