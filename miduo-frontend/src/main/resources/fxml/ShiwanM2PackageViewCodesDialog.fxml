<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2PackageViewCodesDialogController"
      prefWidth="640"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color:white; -fx-border-color:#D9E1EC; -fx-border-width:1;">

    <!-- 标题栏 -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT"
          style="-fx-background-color:#F5F7FA;
                 -fx-border-color:transparent transparent #E5E7EB transparent;
                 -fx-border-width:0 0 1 0;
                 -fx-padding:0 8 0 24;
                 -fx-min-height:56; -fx-pref-height:56;">
        <Label fx:id="titleLabel" text="查看码包"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1F2937; -fx-font-family:'Microsoft YaHei';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" onAction="#onClose"
                style="-fx-background-color:transparent; -fx-text-fill:#9CA3AF; -fx-font-size:26px;
                       -fx-cursor:hand; -fx-min-width:44; -fx-min-height:44;
                       -fx-border-width:0; -fx-background-radius:6; -fx-effect:null; -fx-padding:0;"/>
    </HBox>

    <!-- 内容区 -->
    <VBox spacing="16" VBox.vgrow="ALWAYS"
          style="-fx-padding:20 24 24 24;">

        <!-- 码包信息 -->
        <HBox spacing="24" alignment="CENTER_LEFT"
              style="-fx-background-color:#EFF6FF; -fx-border-color:#BFDBFE; -fx-border-width:1;
                     -fx-border-radius:8; -fx-background-radius:8; -fx-padding:12 16;">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="码包类型："
                       style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                <Label fx:id="packageTypeLabel" text="—"
                       style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="码包名称："
                       style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                <Label fx:id="packageNameLabel" text="—"
                       style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            </HBox>
        </HBox>

        <!-- 搜索区 -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="keywordField" promptText="输入码值搜索..."
                       HBox.hgrow="ALWAYS"
                       style="-fx-font-size:15px; -fx-background-color:white;
                              -fx-border-color:#D1D5DB; -fx-border-width:1;
                              -fx-border-radius:8; -fx-background-radius:8;
                              -fx-min-height:40; -fx-pref-height:40; -fx-padding:0 12;
                              -fx-font-family:'Microsoft YaHei';"/>
            <Button text="搜索" onAction="#onSearch"
                    style="-fx-min-width:80; -fx-pref-width:80; -fx-min-height:40; -fx-pref-height:40;
                           -fx-font-size:15px; -fx-font-weight:bold; -fx-background-color:#2563EB;
                           -fx-text-fill:white; -fx-background-radius:8; -fx-border-width:0;
                           -fx-cursor:hand; -fx-effect:null; -fx-font-family:'Microsoft YaHei';"/>
        </HBox>

        <!-- 表格 -->
        <TableView fx:id="codeTable" VBox.vgrow="ALWAYS"
                   styleClass="sw2-codes-table">
            <columns>
                <TableColumn fx:id="codeValueColumn"        text="码值"     prefWidth="240"/>
                <TableColumn fx:id="associatedStatusColumn" text="关联状态"  prefWidth="140"/>
                <TableColumn fx:id="associatedTimeColumn"   text="关联时间"  prefWidth="220"/>
            </columns>
            <placeholder>
                <Label text="暂无数据"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:14px; -fx-font-family:'Microsoft YaHei';"/>
            </placeholder>
        </TableView>

        <!-- 分页 -->
        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-min-height:44;">
            <Label fx:id="totalLabel" text="共 0 条"
                   style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="每页"
                   style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
            <ComboBox fx:id="pageSizeCombo" prefWidth="90"
                      style="-fx-font-size:14px; -fx-pref-height:32; -fx-min-height:32;">
                <items><FXCollections fx:factory="observableArrayList">
                    <String fx:value="20条"/>
                    <String fx:value="50条"/>
                    <String fx:value="100条"/>
                </FXCollections></items>
                <value><String fx:value="20条"/></value>
            </ComboBox>
            <Button text="上一页" onAction="#onPrevPage"
                    style="-fx-min-width:64; -fx-pref-width:64; -fx-min-height:32; -fx-pref-height:32;
                           -fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#6B7280;
                           -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:6;
                           -fx-border-radius:6; -fx-cursor:hand; -fx-effect:null;"/>
            <Label text="第"
                   style="-fx-font-size:14px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            <TextField fx:id="pageInputField" text="1" prefWidth="48"
                       onAction="#onPageInput"
                       style="-fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#374151;
                              -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-border-radius:6;
                              -fx-background-radius:6; -fx-min-height:32; -fx-pref-height:32;
                              -fx-alignment:CENTER; -fx-padding:0 8; -fx-font-family:'Microsoft YaHei';"/>
            <Label fx:id="totalPagesLabel" text="/ 1 页"
                   style="-fx-font-size:14px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            <Button text="下一页" onAction="#onNextPage"
                    style="-fx-min-width:64; -fx-pref-width:64; -fx-min-height:32; -fx-pref-height:32;
                           -fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#6B7280;
                           -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:6;
                           -fx-border-radius:6; -fx-cursor:hand; -fx-effect:null;"/>
        </HBox>
    </VBox>
</VBox>
