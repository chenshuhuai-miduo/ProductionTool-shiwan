<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 手工采集 Tab -->
<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2ManualController"
      styleClass="sw2-tab-content" spacing="12"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <!-- ——— 左侧（380px）——— -->
    <VBox prefWidth="380" minWidth="380" maxWidth="380" spacing="12">

        <!-- 采集规格设置 -->
        <VBox styleClass="shiwan-m2-card" spacing="12" minHeight="130">
            <Label text="采集规格设置" styleClass="shiwan-m2-card-title"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="1盒" styleClass="shiwan-m2-spec-label"/>
                <TextField fx:id="bottlesPerBoxField" text="6"
                           styleClass="shiwan-m2-spec-input"/>
                <Label text="瓶" styleClass="shiwan-m2-spec-label"/>
            </HBox>
        </VBox>

        <!-- 开始采集提示（填充剩余空间）-->
        <VBox styleClass="shiwan-m2-card" VBox.vgrow="ALWAYS" spacing="12">
            <Label text="开始采集提示" styleClass="shiwan-m2-card-title"/>

            <!-- 码输入区：输入框 + 加入按钮 -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="codeInput"
                           promptText="扫描或输入瓶码"
                           onAction="#onCodeInputSubmit"
                           disable="true"
                           HBox.hgrow="ALWAYS"
                           style="-fx-min-height: 44px; -fx-font-size: 15px;
                                  -fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-background-color: #F9FAFB;
                                  -fx-padding: 0 12; -fx-font-family: 'Microsoft YaHei';"/>
                <Button fx:id="addBtn" text="加入"
                        onAction="#onCodeInputSubmit"
                        disable="true"
                        style="-fx-min-height: 44px; -fx-min-width: 72px; -fx-pref-width: 72px;
                               -fx-background-color: #D1D5DB; -fx-text-fill: white;
                               -fx-font-size: 15px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-border-width: 0;
                               -fx-effect: null; -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>

            <!-- 当前应扫提示（蓝底圆角卡片，固定高度）-->
            <VBox alignment="CENTER" spacing="12" prefHeight="120" minHeight="120" maxHeight="120"
                  style="-fx-background-color: #EEF5FF;
                         -fx-background-radius: 10;
                         -fx-border-color: #C7DBFF;
                         -fx-border-radius: 10;
                         -fx-padding: 18 22;">
                <Label text="当前应扫" styleClass="sw2-prompt-main"/>
                <Label fx:id="promptCodeLabel" text="瓶码" styleClass="sw2-prompt-code-active"/>
            </VBox>
        </VBox>
    </VBox>

    <!-- ——— 中间（flex）——— -->
    <VBox HBox.hgrow="ALWAYS" spacing="12">

        <!-- 数据接收区 -->
        <VBox styleClass="shiwan-m2-area-card" VBox.vgrow="ALWAYS">
            <HBox styleClass="shiwan-m2-area-header-bar">
                <Label text="数据接收区" styleClass="shiwan-m2-area-header-label"/>
                <Label text="（最新在上）" styleClass="shiwan-m2-area-header-hint"/>
            </HBox>
            <ListView fx:id="dataLogList" VBox.vgrow="ALWAYS" styleClass="shiwan-m2-log-list"/>
        </VBox>

        <!-- 操作日志 -->
        <VBox styleClass="shiwan-m2-area-card" VBox.vgrow="ALWAYS">
            <HBox styleClass="shiwan-m2-area-header-bar">
                <Label text="操作日志" styleClass="shiwan-m2-area-header-label"/>
                <Label text="（最新在上）" styleClass="shiwan-m2-area-header-hint"/>
            </HBox>
            <ListView fx:id="opLogList" VBox.vgrow="ALWAYS" styleClass="shiwan-m2-log-list"/>
        </VBox>
    </VBox>

    <!-- ——— 右侧（380px）——— -->
    <VBox prefWidth="380" minWidth="380" maxWidth="380" spacing="12">

        <!-- 单位实时统计 -->
        <VBox styleClass="shiwan-m2-card" spacing="8">
            <Label text="单位实时统计" styleClass="shiwan-m2-card-title"/>
            <HBox spacing="8" prefHeight="115" maxHeight="115">
                <VBox styleClass="shiwan-m2-stat-card"
                      HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                    <Label text="当前已读" styleClass="shiwan-m2-stat-label"/>
                    <Label fx:id="currentCountLabel" text="0"
                           styleClass="shiwan-m2-stat-num-red"/>
                </VBox>
                <VBox styleClass="shiwan-m2-stat-card"
                      HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                    <Label text="每盒瓶数" styleClass="shiwan-m2-stat-label"/>
                    <Label fx:id="perBoxCountLabel" text="6"
                           styleClass="shiwan-m2-stat-num-blue"/>
                </VBox>
            </HBox>
            <!-- 生产总数 -->
            <HBox styleClass="shiwan-m2-stats-line" alignment="CENTER_LEFT">
                <Label text="生产总数"
                       styleClass="shiwan-m2-stats-line-label"
                       HBox.hgrow="ALWAYS"/>
                <Label fx:id="totalCountLabel" text="0"
                       styleClass="shiwan-m2-stats-line-val"/>
            </HBox>
        </VBox>

        <!-- 任务控制（填充剩余高度）-->
        <VBox styleClass="shiwan-m2-card" VBox.vgrow="ALWAYS" spacing="12">
            <Label text="任务控制" styleClass="shiwan-m2-card-title"/>
            <GridPane hgap="12" vgap="14">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <Button fx:id="startBtn" text="开始采集"
                        styleClass="shiwan-m2-ctrl-btn-primary"
                        onAction="#onToggleCapture"
                        maxWidth="Infinity"
                        GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Button text="清零"
                        styleClass="shiwan-m2-ctrl-btn-outline-blue"
                        onAction="#onReset"
                        maxWidth="Infinity"
                        GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            </GridPane>
        </VBox>
    </VBox>
</HBox>
