<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2HelpController"
      prefWidth="920" prefHeight="660"
      style="-fx-background-color: white;">

    <!-- ====================================================
         标题栏
         ==================================================== -->
    <HBox alignment="CENTER_LEFT" spacing="8"
          minHeight="52" maxHeight="52"
          style="-fx-background-color: #F9FAFB;
                 -fx-border-color: transparent transparent #E5E7EB transparent;
                 -fx-border-width: 0 0 1px 0;
                 -fx-padding: 0 12px 0 20px;">
        <Label text="📖 操作帮助"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2937;
                      -fx-font-family: 'Microsoft YaHei';"
               HBox.hgrow="ALWAYS"/>
        <Button fx:id="closeBtn" text="✕"
                style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF;
                       -fx-font-size: 16px; -fx-cursor: hand; -fx-border-width: 0;
                       -fx-padding: 4px 10px; -fx-background-radius: 4px;"
                onAction="#onClose"/>
    </HBox>

    <!-- ====================================================
         内容区：左侧目录 + 右侧正文
         ==================================================== -->
    <HBox VBox.vgrow="ALWAYS" minHeight="0">

        <!-- 左侧目录 (180px，固定宽度) -->
        <ScrollPane prefWidth="180" minWidth="180" maxWidth="180"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: #F9FAFB;
                           -fx-border-color: transparent #E5E7EB transparent transparent;
                           -fx-border-width: 0 1px 0 0;
                           -fx-background-insets: 0;
                           -fx-padding: 0;">
            <VBox fx:id="tocContainer" spacing="0"
                  style="-fx-padding: 12px 0; -fx-background-color: #F9FAFB;">
                <!-- 目录项由控制器动态添加 -->
                <Label text="目 录"
                       style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;
                              -fx-font-weight: bold; -fx-padding: 0 16px 10px 16px;
                              -fx-letter-spacing: 1px;"/>
            </VBox>
        </ScrollPane>

        <!-- 右侧正文 ScrollPane（占剩余宽度） -->
        <ScrollPane fx:id="contentScrollPane"
                    HBox.hgrow="ALWAYS"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: white;
                           -fx-border-width: 0;
                           -fx-background-insets: 0;
                           -fx-padding: 0;">
            <!-- 正文内容由控制器动态填充 -->
            <VBox fx:id="contentContainer" spacing="0"
                  style="-fx-padding: 0; -fx-background-color: white;"/>
        </ScrollPane>

    </HBox>

    <!-- ====================================================
         底部按钮栏
         ==================================================== -->
    <HBox alignment="CENTER_RIGHT" spacing="12"
          minHeight="52" maxHeight="52"
          style="-fx-background-color: #F9FAFB;
                 -fx-border-color: #E5E7EB transparent transparent transparent;
                 -fx-border-width: 1px 0 0 0;
                 -fx-padding: 0 20px;">
        <Button text="关 闭"
                style="-fx-background-color: #F3F4F6; -fx-text-fill: #374151;
                       -fx-border-width: 0; -fx-background-radius: 6px;
                       -fx-min-width: 90px; -fx-min-height: 36px;
                       -fx-font-size: 14px; -fx-cursor: hand;
                       -fx-font-family: 'Microsoft YaHei';"
                onAction="#onClose"/>
    </HBox>

</VBox>
