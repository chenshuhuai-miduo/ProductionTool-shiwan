<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2HelpController"
      prefWidth="920" prefHeight="660"
      style="-fx-background-color: white;
             -fx-background-radius: 12px;
             -fx-border-color: #D9E1EC;
             -fx-border-width: 1px;
             -fx-border-radius: 12px;">

    <!-- ====================================================
         标题栏
         ==================================================== -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="8"
          minHeight="56" maxHeight="56"
          style="-fx-background-color: #2563EB;
                 -fx-background-radius: 12px 12px 0 0;
                 -fx-padding: 0 16px 0 24px;">
        <Label text="操作帮助"
               maxWidth="Infinity"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;
                      -fx-font-family: 'Microsoft YaHei';"
               HBox.hgrow="ALWAYS"/>
        <Button fx:id="closeBtn" text="×"
                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                       -fx-font-size: 20px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-border-width: 0; -fx-min-width: 32px; -fx-min-height: 32px;
                       -fx-max-width: 32px; -fx-max-height: 32px;
                       -fx-background-radius: 6px; -fx-padding: 0;"
                onAction="#onClose"/>
    </HBox>

    <!-- ====================================================
         内容区：左侧目录 + 右侧正文
         ==================================================== -->
    <HBox VBox.vgrow="ALWAYS" minHeight="0">

        <!-- 左侧目录 (200px，固定宽度) -->
        <ScrollPane prefWidth="200" minWidth="200" maxWidth="200"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: #F8FAFC;
                           -fx-border-color: transparent #E5E7EB transparent transparent;
                           -fx-border-width: 0 1px 0 0;
                           -fx-background-insets: 0;
                           -fx-padding: 0;">
            <VBox fx:id="tocContainer" spacing="4"
                  style="-fx-padding: 16px; -fx-background-color: #F8FAFC;">
                <!-- 目录标题 -->
                <Label text="目录"
                       style="-fx-font-size: 17px; -fx-text-fill: #374151;
                              -fx-font-weight: bold; -fx-font-family: 'Microsoft YaHei';
                              -fx-padding: 0 0 4px 0;"/>
                <!-- 分隔线 -->
                <Region prefHeight="1" maxHeight="1" minHeight="1"
                        style="-fx-background-color: #E5E7EB;" VBox.vgrow="NEVER"/>
                <!-- 目录项由控制器动态添加 -->
            </VBox>
        </ScrollPane>

        <!-- 右侧正文 ScrollPane（占剩余宽度） -->
        <ScrollPane fx:id="contentScrollPane"
                    HBox.hgrow="ALWAYS"
                    fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: white;
                           -fx-border-width: 0;
                           -fx-background-insets: 0;
                           -fx-padding: 0;">
            <!-- 正文内容由控制器动态填充 -->
            <VBox fx:id="contentContainer" spacing="0"
                  style="-fx-padding: 0; -fx-background-color: white;"/>
        </ScrollPane>

    </HBox>


</VBox>
