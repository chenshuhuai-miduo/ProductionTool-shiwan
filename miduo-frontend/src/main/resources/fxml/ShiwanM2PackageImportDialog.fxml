<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2PackageImportDialogController"
      prefWidth="520"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color: white;
             -fx-border-color: #D9E1EC;
             -fx-border-width: 1;">

    <!-- 自定义标题栏（可拖拽） -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT"
          style="-fx-background-color: #F5F7FA;
                 -fx-border-color: transparent transparent #E5E7EB transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 0 8 0 24;
                 -fx-min-height: 56; -fx-pref-height: 56;">
        <Label text="码包导入"
               style="-fx-font-size: 18px; -fx-font-weight: bold;
                      -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="closeBtn" text="×" onAction="#onCancel"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #9CA3AF; -fx-font-size: 26px;
                       -fx-cursor: hand; -fx-min-width: 44; -fx-min-height: 44;
                       -fx-border-width: 0; -fx-background-radius: 6;
                       -fx-effect: null; -fx-padding: 0;"/>
    </HBox>

    <!-- 表单区 -->
    <VBox spacing="20" style="-fx-padding: 28;">

        <!-- 码包类型 -->
        <VBox spacing="6">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="*" style="-fx-text-fill: #EF4444; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label text="码包类型" style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>
            <ComboBox fx:id="packageTypeCombo" maxWidth="Infinity"
                      style="-fx-min-height: 40px; -fx-font-size: 14px;
                             -fx-border-color: #D1D5DB; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-background-color: #F9FAFB;
                             -fx-font-family: 'Microsoft YaHei';"/>
        </VBox>

        <!-- 选择文件 -->
        <VBox spacing="6">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="*" style="-fx-text-fill: #EF4444; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label text="选择文件" style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="selectedFileField" editable="false" promptText="未选择文件"
                           HBox.hgrow="ALWAYS"
                           style="-fx-min-height: 40px; -fx-font-size: 14px;
                                  -fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-background-color: #F9FAFB;
                                  -fx-padding: 0 12; -fx-font-family: 'Microsoft YaHei';"/>
                <Button text="浏览" onAction="#onBrowseFile"
                        style="-fx-min-height: 40px; -fx-pref-width: 88px;
                               -fx-background-color: #F3F4F6; -fx-text-fill: #374151;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-color: #D1D5DB; -fx-border-radius: 8;
                               -fx-border-width: 1; -fx-cursor: hand; -fx-effect: null;
                               -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>
            <Label text="仅支持 .txt 格式，文件大小不超过 50MB"
                   style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
        </VBox>

        <!-- 备注（选填） -->
        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT">
                <Label text="备注"
                       style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="最多 50 字"
                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>
            <TextArea fx:id="remarkField" promptText="选填，如：2024-12-01批次"
                      prefHeight="72" minHeight="72" maxHeight="72"
                      wrapText="true"
                      style="-fx-font-size: 14px;
                             -fx-border-color: #D1D5DB; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-background-color: #F9FAFB;
                             -fx-padding: 10 12; -fx-font-family: 'Microsoft YaHei';"/>
        </VBox>

        <!-- 密码 -->
        <VBox spacing="6">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="*" style="-fx-text-fill: #EF4444; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label text="密码" style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>
            <PasswordField fx:id="passwordField" promptText="请输入密码"
                           style="-fx-min-height: 40px; -fx-font-size: 14px;
                                  -fx-border-color: #D1D5DB; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-background-color: #F9FAFB;
                                  -fx-padding: 0 12; -fx-font-family: 'Microsoft YaHei';"/>
        </VBox>

        <!-- 错误提示 -->
        <Label fx:id="tipsLabel"
               style="-fx-text-fill: #DC2626; -fx-font-size: 13px; -fx-font-family: 'Microsoft YaHei';"/>
    </VBox>

    <!-- 底部按钮区 -->
    <HBox alignment="CENTER" spacing="12"
          style="-fx-background-color: #F9FAFB;
                 -fx-border-color: #E5E7EB transparent transparent transparent;
                 -fx-border-width: 1 0 0 0;
                 -fx-min-height: 72; -fx-pref-height: 72;
                 -fx-padding: 0 24;">
        <Button text="取消" onAction="#onCancel"
                style="-fx-min-height: 40px; -fx-pref-width: 90px;
                       -fx-background-color: #F3F4F6; -fx-border-width: 0;
                       -fx-background-radius: 8; -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-text-fill: #374151; -fx-cursor: hand; -fx-effect: null;
                       -fx-font-family: 'Microsoft YaHei';"/>
        <Button text="确认导入" onAction="#onConfirmImport"
                style="-fx-min-height: 40px; -fx-pref-width: 110px;
                       -fx-background-color: #2563EB; -fx-border-width: 0;
                       -fx-background-radius: 8; -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-text-fill: white; -fx-cursor: hand; -fx-effect: null;
                       -fx-font-family: 'Microsoft YaHei';"/>
    </HBox>
</VBox>
