<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2SystemSettingsController"
      fx:id="rootBox"
      prefWidth="1000" prefHeight="768"
      style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1;">
    <stylesheets>
        <URL value="@../css/base-styles.css"/>
        <URL value="@../css/shiwan-m2-styles.css"/>
    </stylesheets>

    <!-- ====================================================
         自定义标题栏（可拖拽）
         ==================================================== -->
    <HBox fx:id="titleBar"
          alignment="CENTER_LEFT"
          style="-fx-background-color: #f0f0f0;
                 -fx-border-color: transparent transparent #e0e0e0 transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 0 8 0 24;
                 -fx-min-height: 48; -fx-pref-height: 48;"
          onMousePressed="#onTitleBarPressed"
          onMouseDragged="#onTitleBarDragged">
        <Label text="系统设置"
               style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #333333;
                      -fx-font-family: 'Microsoft YaHei';"/>
        <!-- 占位符，将关闭按钮推到最右 -->
        <Region HBox.hgrow="ALWAYS"/>
        <!-- 关闭按钮，同参考弹窗风格 -->
        <Button fx:id="closeBtn" text="×" onAction="#onClose"
                style="-fx-background-color: transparent; -fx-text-fill: #9CA3AF; -fx-font-size: 26px;
                       -fx-cursor: hand; -fx-min-width: 44; -fx-min-height: 44;
                       -fx-border-width: 0; -fx-background-radius: 6; -fx-effect: null; -fx-padding: 0;"/>
    </HBox>

    <!-- ====================================================
         主体：一级 TabPane
         ==================================================== -->
    <TabPane fx:id="mainTabPane"
             VBox.vgrow="ALWAYS"
             tabClosingPolicy="UNAVAILABLE"
             styleClass="sw2-settings-tab-pane">

        <!-- ============ Tab1：业务 ============ -->
        <Tab text="业务">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="sw2-settings-inner-tab-pane">

                <!-- 码位数配置 -->
                <Tab text="码位数配置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="码位数配置（采集时校验码位数，-1 表示不校验）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;
                                          -fx-font-family: 'Microsoft YaHei';"/>

                            <!-- 小标位数 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="小标位数（瓶码）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField fx:id="smallCodeDigitsField"
                                           text="14"
                                           prefWidth="100"
                                           styleClass="text-field"
                                           promptText="如 14，-1 不校验"/>
                            </HBox>

                            <!-- 中标位数 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="中标位数（盒码）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField fx:id="mediumCodeDigitsField"
                                           text="14"
                                           prefWidth="100"
                                           styleClass="text-field"
                                           promptText="如 14，-1 不校验"/>
                            </HBox>

                            <!-- 大标位数 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="大标位数（箱码）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField fx:id="largeCodeDigitsField"
                                           text="-1"
                                           prefWidth="100"
                                           styleClass="text-field"
                                           promptText="-1 不校验"/>
                            </HBox>

                            <Label text="说明：-1 表示不校验该层级位数；采集时若实际采码位数与配置值不一致，则异常告警、关联失败。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保 存"
                                    styleClass="primary-button"
                                    onAction="#onSaveCodeDigits"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 虚拟垛标规则 -->
                <Tab text="虚拟垛标规则">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="虚拟垛标规则（成垛时生成虚拟垛标，格式示例：V20260226001A12）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <!-- 前缀 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="前缀"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField fx:id="palletPrefixField"
                                           text="V"
                                           prefWidth="100"
                                           styleClass="text-field"
                                           promptText="默认 V"/>
                            </HBox>

                            <!-- 时间（只读） -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="时间"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField text="YYYYMMDD（生成时取当前日期）"
                                           prefWidth="220"
                                           editable="false"
                                           style="-fx-font-size: 13px; -fx-background-color: #F3F4F6;
                                                  -fx-text-fill: #6B7280; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 6px;
                                                  -fx-background-radius: 6px; -fx-min-height: 36px;
                                                  -fx-padding: 0 10px;"/>
                            </HBox>

                            <!-- 序号（只读） -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="序号"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField text="001（自动递增，不可修改）"
                                           prefWidth="220"
                                           editable="false"
                                           style="-fx-font-size: 13px; -fx-background-color: #F3F4F6;
                                                  -fx-text-fill: #6B7280; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 6px;
                                                  -fx-background-radius: 6px; -fx-min-height: 36px;
                                                  -fx-padding: 0 10px;"/>
                            </HBox>

                            <!-- 产线号 -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="产线号"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField fx:id="palletLineNumField"
                                           text="A"
                                           prefWidth="100"
                                           styleClass="text-field"
                                           promptText="如 A、B"/>
                            </HBox>

                            <!-- 随机数（只读） -->
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="随机数"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140"/>
                                <TextField text="12（系统自动生成 2位，不可修改）"
                                           prefWidth="220"
                                           editable="false"
                                           style="-fx-font-size: 13px; -fx-background-color: #F3F4F6;
                                                  -fx-text-fill: #6B7280; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 6px;
                                                  -fx-background-radius: 6px; -fx-min-height: 36px;
                                                  -fx-padding: 0 10px;"/>
                            </HBox>

                            <Label text="说明：时间、序号、随机数为生成时自动取值，不可修改；前缀、产线号可修改。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保 存"
                                    styleClass="primary-button"
                                    onAction="#onSavePalletRule"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 上传配置 -->
                <Tab text="上传配置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="上传配置（成垛后自动上传至米多大数据引擎）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;
                                          -fx-font-family: 'Microsoft YaHei';"/>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="自动上传"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="100"/>
                                <ToggleButton fx:id="autoUploadToggle"
                                              text="已开启"
                                              selected="true"
                                              styleClass="sw2-toggle-switch"
                                              onAction="#onAutoUploadToggled"/>
                            </HBox>

                            <Label text="开启时：成垛后自动上传数据至米多大数据引擎；关闭时：成垛后不自动上传，需手动上传。"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保 存"
                                    styleClass="primary-button"
                                    onAction="#onSaveUploadConfig"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 入库仓库设置 -->
                <Tab text="入库仓库设置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="入库仓库设置（上传垛码关联数据时传入仓库编号）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="仓库编号（warehouseNo）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="200"/>
                                <TextField fx:id="warehouseNoField"
                                           text="001"
                                           prefWidth="160"
                                           styleClass="text-field"
                                           promptText="如 001"/>
                            </HBox>

                            <Label text="说明：上传垛码关联数据至开放平台时，将该仓库编号作为入参 warehouseno 传入，默认值为 001。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保 存"
                                    styleClass="primary-button"
                                    onAction="#onSaveWarehouseNo"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </Tab>

        <!-- ============ Tab2：页面配置 ============ -->
        <Tab text="页面配置">
            <VBox spacing="0" style="-fx-background-color: white;">
                <VBox spacing="12" style="-fx-padding: 20px 24px 0 24px;">
                    <Label text="控制主界面 Tab 栏显示哪些页面。Switch 开启 = Tab 显示，关闭 = Tab 隐藏。配置保存至配置文件，重启后生效。"
                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                           wrapText="true"/>
                </VBox>

                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER"
                            style="-fx-background-color: white; -fx-border-width: 0; -fx-padding: 0;">
                    <VBox spacing="0" style="-fx-padding: 0 24px 16px 24px; -fx-background-color: white;">

                        <!-- 表头 -->
                        <HBox style="-fx-background-color: #F3F4F6; -fx-border-color: #E5E7EB; -fx-border-width: 1px;
                                     -fx-padding: 10px 14px;" spacing="12">
                            <Label text="页面名称"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="功能说明"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <Label text="显示"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="80" alignment="CENTER"/>
                        </HBox>

                        <!-- 行1：数据采集（必选） -->
                        <HBox style="-fx-background-color: white; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="数据采集（盒箱垛）"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="主界面，盒箱垛关联数据采集（必选不可关闭）"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton text="开" selected="true" disable="true"
                                          styleClass="sw2-toggle-switch sw2-toggle-disabled"
                                          minWidth="56" minHeight="28"/>
                        </HBox>

                        <!-- 行2：手工采集 -->
                        <HBox style="-fx-background-color: #FAFAFA; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="手工采集"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="扫码枪手工采集，相机损坏时替代"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pageManualToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                        <!-- 行3：数据查询 -->
                        <HBox style="-fx-background-color: white; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="数据查询"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="查询采集关联数据"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pageQueryToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                        <!-- 行4：数据替换 -->
                        <HBox style="-fx-background-color: #FAFAFA; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="数据替换"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="码替换操作"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pageReplaceToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                        <!-- 行5：生产统计 -->
                        <HBox style="-fx-background-color: white; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="生产统计"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="生产统计报表"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pageStatsToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                        <!-- 行6：码包管理 -->
                        <HBox style="-fx-background-color: #FAFAFA; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="码包管理"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="码包导入与管理"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pagePackageToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                        <!-- 行7：取消关联 -->
                        <HBox style="-fx-background-color: white; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="取消关联"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="单个/批量取消关联"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pageCancelToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                        <!-- 行8：数据上传 -->
                        <HBox style="-fx-background-color: #FAFAFA; -fx-border-color: transparent #E5E7EB #E5E7EB #E5E7EB;
                                     -fx-border-width: 0 1px 1px 1px; -fx-padding: 10px 14px;" spacing="12" alignment="CENTER_LEFT">
                            <Label text="数据上传"
                                   style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"
                                   minWidth="140" maxWidth="140"/>
                            <Label text="手动上传、上传状态查询"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   HBox.hgrow="ALWAYS"/>
                            <ToggleButton fx:id="pageUploadToggle" text="开" selected="true"
                                          styleClass="sw2-toggle-switch"
                                          minWidth="56" minHeight="28"
                                          onAction="#onPageToggleChanged"/>
                        </HBox>

                    </VBox>
                </ScrollPane>

                <!-- 保存按钮 -->
                <HBox style="-fx-padding: 12px 24px; -fx-border-color: #E5E7EB transparent transparent transparent;
                             -fx-border-width: 1px 0 0 0;">
                    <Button text="保 存"
                            styleClass="primary-button"
                            onAction="#onSavePageConfig"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- ============ Tab3：设备 ============ -->
        <Tab text="设备">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="sw2-settings-inner-tab-pane">

                <!-- IO设备管理 -->
                <Tab text="IO设备管理">
                    <VBox spacing="0" style="-fx-background-color: white;">
                        <!-- 工具栏 -->
                        <HBox spacing="10" styleClass="tool-bar" alignment="CENTER_LEFT">
                            <Button text="+ 添加设备" styleClass="primary-button"
                                    onAction="#onAddIoDevice"/>
                            <Button text="测试所有设备" styleClass="secondary-button"
                                    onAction="#onTestAllDevices"/>
                        </HBox>
                        <!-- 设备列表 -->
                        <TableView fx:id="ioDeviceTable"
                                   VBox.vgrow="ALWAYS"
                                   styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="deviceNameCol" text="设备名称" prefWidth="130"/>
                                <TableColumn fx:id="deviceTypeCol" text="设备类型" prefWidth="120"/>
                                <TableColumn fx:id="deviceAddrCol" text="连接地址" prefWidth="160"/>
                                <TableColumn fx:id="devicePortCol" text="端口" prefWidth="80"/>
                                <TableColumn fx:id="deviceStatusCol" text="状态" prefWidth="120"/>
                                <TableColumn fx:id="deviceActionCol" text="操作" prefWidth="220"/>
                            </columns>
                            <placeholder>
                                <Label text="暂无设备配置，点击「+ 添加设备」按钮添加"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- 设备控制配置 -->
                <Tab text="设备控制配置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="12" style="-fx-padding: 20px 24px;">

                            <!-- 剔除装置 -->
                            <Label text="剔除装置"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"/>
                            <Separator style="-fx-background-color: #E5E7EB;"/>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="触发剔除延时（ms）："
                                       minWidth="160"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="rejectTriggerDelayField"
                                           promptText="1000"
                                           prefWidth="120"
                                           styleClass="text-field"/>
                                <Label text="检测到需要剔除后，等待该时间再发送信号"
                                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="剔除收回时间（ms）："
                                       minWidth="160"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="rejectRetractTimeField"
                                           promptText="600"
                                           prefWidth="120"
                                           styleClass="text-field"/>
                                <Label text="发送剔除信号后，等待该时间自动发送收回信号"
                                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox>
                                <Button text="保存"
                                        styleClass="primary-button"
                                        onAction="#onSaveDeviceSignalConfig"/>
                            </HBox>

                            <!-- 盒箱相机采集间隔 -->
                            <Label text="盒箱相机采集间隔"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"/>
                            <Separator style="-fx-background-color: #E5E7EB;"/>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="双相机等待超时（ms）："
                                       minWidth="160"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="boxCaseCameraMatchWaitTimeoutField"
                                           promptText="3000"
                                           prefWidth="120"
                                           styleClass="text-field"/>
                                <Label text="一侧收到批数据后，等待另一侧同批号的最长时间；0 表示不启用超时剔除"
                                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox>
                                <Button text="保存"
                                        styleClass="primary-button"
                                        onAction="#onSaveBoxCaseCameraCaptureConfig"/>
                            </HBox>

                            <!-- 隐藏的信号字段（保留供控制器注入，不在界面显示） -->
                            <VBox managed="false" visible="false">
                                <TextField fx:id="cmdAllOffField"/>
                                <TextField fx:id="cmdNormalOnField"/>
                                <TextField fx:id="cmdNormalWithRejectField"/>
                                <TextField fx:id="cmdUploadSuccessField"/>
                                <TextField fx:id="cmdUploadSuccessWithRejectField"/>
                                <TextField fx:id="cmdUploadFailField"/>
                                <TextField fx:id="cmdUploadFailWithRejectField"/>
                                <TextField fx:id="alarmOpenHexField"/>
                                <TextField fx:id="alarmCloseHexField"/>
                                <TextField fx:id="alarmLightOnHexField"/>
                                <TextField fx:id="alarmLightOffHexField"/>
                                <TextField fx:id="rejectTriggerHexField"/>
                                <TextField fx:id="rejectRetractHexField"/>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </Tab>

        <!-- ============ Tab4：连接 ============ -->
        <Tab text="连接">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="sw2-settings-inner-tab-pane">

                <!-- 数据库连接（本机 + 1号机合并） -->
                <Tab text="数据库连接">
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
                        <VBox spacing="14" style="-fx-padding: 20px 24px;">

                            <!-- 本机数据库 section header -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="本机数据库（2号机自身）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"/>
                                <Label text="MySQL"
                                       style="-fx-background-color: #D1FAE5; -fx-text-fill: #065F46;
                                              -fx-background-radius: 20px; -fx-padding: 2px 10px;
                                              -fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="IP地址："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbHostField"
                                           prefWidth="220" styleClass="text-field"
                                           promptText="localhost"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="端口："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbPortField"
                                           prefWidth="120" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="数据库名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbNameField"
                                           prefWidth="220" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="用户名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbUserField"
                                           prefWidth="160" styleClass="text-field"/>
                                <Label text="密码："
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <PasswordField fx:id="dbPasswordField"
                                               prefWidth="160" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button text="连接测试"
                                        styleClass="secondary-button"
                                        onAction="#onTestDbConnection"/>
                                <Label fx:id="dbTestResultLabel"
                                       text=""
                                       style="-fx-font-size: 13px; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <Separator style="-fx-background-color: #E5E7EB; -fx-padding: 4px 0;"/>

                            <!-- 1号机数据库 section header -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="1号机数据库（轮询同步源）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"/>
                                <Label text="SQLServer"
                                       style="-fx-background-color: #DBEAFE; -fx-text-fill: #1E40AF;
                                              -fx-background-radius: 20px; -fx-padding: 2px 10px;
                                              -fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="IP地址："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbHostField"
                                           prefWidth="220" styleClass="text-field"
                                           promptText="192.168.1.xxx"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="端口："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbPortField"
                                           prefWidth="120" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="数据库名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbNameField"
                                           prefWidth="220" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="表名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbTableField"
                                           prefWidth="220" styleClass="text-field"
                                           promptText="默认 T_Code"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="用户名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbUserField"
                                           prefWidth="160" styleClass="text-field"/>
                                <Label text="密码："
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <PasswordField fx:id="m1DbPasswordField"
                                               prefWidth="160" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button text="连接测试"
                                        styleClass="secondary-button"
                                        onAction="#onTestM1DbConnection"/>
                                <Label fx:id="m1DbTestResultLabel"
                                       text=""
                                       style="-fx-font-size: 13px; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <!-- 隐藏的初始同步游标字段，保留供控制器注入 -->
                            <TextField fx:id="m1InitialSerialNoField" managed="false" visible="false"/>

                            <HBox spacing="10">
                                <Button text="保存本机配置"
                                        styleClass="primary-button"
                                        onAction="#onSaveDbConfig"/>
