<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2SystemSettingsController"
      fx:id="rootBox"
      prefWidth="1000" prefHeight="768"
      style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1;">
    <stylesheets>
        <URL value="@../css/base-styles.css"/>
        <URL value="@../css/shiwan-m2-styles.css"/>
    </stylesheets>

    <!-- ====================================================
         自定义标题栏（可拖拽）
         ==================================================== -->
    <HBox fx:id="titleBar"
          alignment="CENTER_LEFT"
          style="-fx-background-color: #f0f0f0;
                 -fx-border-color: transparent transparent #e0e0e0 transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 0 8 0 24;
                 -fx-min-height: 48; -fx-pref-height: 48;"
          onMousePressed="#onTitleBarPressed"
          onMouseDragged="#onTitleBarDragged">
        <Label text="系统设置"
               style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #333333;
                      -fx-font-family: 'Microsoft YaHei';"/>
        <!-- 占位符，将关闭按钮推到最右 -->
        <Region HBox.hgrow="ALWAYS"/>
        <!-- 关闭按钮，同参考弹窗风格 -->
        <Button fx:id="closeBtn" text="×" onAction="#onClose" styleClass="sw2-dialog-title-close-btn"/>
    </HBox>

    <!-- ====================================================
         主体：一级 TabPane
         ==================================================== -->
    <TabPane fx:id="mainTabPane"
             VBox.vgrow="ALWAYS"
             tabClosingPolicy="UNAVAILABLE"
             styleClass="sw2-settings-tab-pane">

        <!-- ============ Tab1：业务 ============ -->
        <Tab text="业务">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="sw2-settings-inner-tab-pane">

                <!-- 码位数配置（对齐设计稿 Ecp9q / dgeX1 共用页面.pen） -->
                <Tab text="码位数配置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="12" style="-fx-padding: 20px;">
                            <Label text="码位数配置（采集时校验码位数，-1表示不校验）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <!-- 小标位数 -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="小标位数（瓶码）:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140" prefWidth="140" alignment="CENTER_RIGHT"/>
                                <TextField fx:id="smallCodeDigitsField"
                                           text="14"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           style="-fx-font-size: 14px; -fx-background-color: #ffffff;
                                                  -fx-text-fill: #666666; -fx-border-color: #e0e0e0;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"
                                           promptText="如 14，-1 不校验"/>
                            </HBox>

                            <!-- 中标位数 -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="中标位数（盒码）:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140" prefWidth="140" alignment="CENTER_RIGHT"/>
                                <TextField fx:id="mediumCodeDigitsField"
                                           text="14"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           style="-fx-font-size: 14px; -fx-background-color: #ffffff;
                                                  -fx-text-fill: #666666; -fx-border-color: #e0e0e0;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"
                                           promptText="如 14，-1 不校验"/>
                            </HBox>

                            <!-- 大标位数 -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="大标位数（箱码）:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="140" prefWidth="140" alignment="CENTER_RIGHT"/>
                                <TextField fx:id="largeCodeDigitsField"
                                           text="-1"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           style="-fx-font-size: 14px; -fx-background-color: #ffffff;
                                                  -fx-text-fill: #666666; -fx-border-color: #e0e0e0;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"
                                           promptText="-1 不校验"/>
                            </HBox>

                            <Label text="说明：-1 表示不校验该层级位数；采集时若实际采码位数与配置值不一致，则异常告警、关联失败。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Region minHeight="20" prefHeight="20" maxHeight="20"/>

                            <Button text="保存" mnemonicParsing="false"
                                    styleClass="primary-button, sw2-settings-save-btn"
                                    onAction="#onSaveCodeDigits"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 虚拟垛标规则 -->
                <Tab text="虚拟垛标规则">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <!-- 文案对齐设计稿 gmVUq（共用页面.pen） -->
                            <Label text="虚拟垛标规则（成垛时生成，格式示例：V20260226001A12）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <!-- 前缀 -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="前缀:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="90" prefWidth="90" alignment="CENTER_RIGHT"/>
                                <TextField fx:id="palletPrefixField"
                                           text="V"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           style="-fx-font-size: 14px; -fx-background-color: #ffffff;
                                                  -fx-text-fill: #333333; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"
                                           promptText="默认 V"/>
                            </HBox>

                            <!-- 时间（只读） -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="时间:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="90" prefWidth="90" alignment="CENTER_RIGHT"/>
                                <TextField text="YYYYMMDD"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           editable="false"
                                           style="-fx-font-size: 14px; -fx-background-color: #F3F4F6;
                                                  -fx-text-fill: #6B7280; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"/>
                            </HBox>

                            <!-- 序号（只读） -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="序号:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="90" prefWidth="90" alignment="CENTER_RIGHT"/>
                                <TextField text="001"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           editable="false"
                                           style="-fx-font-size: 14px; -fx-background-color: #F3F4F6;
                                                  -fx-text-fill: #6B7280; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"/>
                            </HBox>

                            <!-- 产线号 -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="产线号:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="90" prefWidth="90" alignment="CENTER_RIGHT"/>
                                <TextField fx:id="palletLineNumField"
                                           text="A"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           style="-fx-font-size: 14px; -fx-background-color: #ffffff;
                                                  -fx-text-fill: #333333; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"
                                           promptText="如 A、B"/>
                            </HBox>

                            <!-- 随机数（只读） -->
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="随机数:"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="90" prefWidth="90" alignment="CENTER_RIGHT"/>
                                <TextField text="2位自动生成"
                                           minWidth="120" prefWidth="120" maxWidth="120"
                                           editable="false"
                                           style="-fx-font-size: 14px; -fx-background-color: #F3F4F6;
                                                  -fx-text-fill: #6B7280; -fx-border-color: #D1D5DB;
                                                  -fx-border-width: 1px; -fx-border-radius: 4px;
                                                  -fx-background-radius: 4px; -fx-min-height: 32px;
                                                  -fx-pref-height: 32px; -fx-padding: 6 12;"/>
                            </HBox>

                            <Label text="说明：时间、序号、随机数为生成时自动取值，不可修改；前缀、产线号可修改。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保存" mnemonicParsing="false"
                                    styleClass="primary-button, sw2-settings-save-btn"
                                    onAction="#onSavePalletRule"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 上传配置 -->
                <Tab text="上传配置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="上传配置（成垛后自动上传至米多大数据引擎）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"/>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="自动上传"
                                       style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="100"/>
                                <ToggleButton fx:id="autoUploadToggle"
                                              text=""
                                              selected="true"
                                              styleClass="sw2-page-toggle-switch"
                                              onAction="#onAutoUploadToggled"/>
                            </HBox>

                            <Label text="开启时成垛后自动上传；关闭时需手动上传。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保存" mnemonicParsing="false"
                                    styleClass="primary-button, sw2-settings-save-btn"
                                    onAction="#onSaveUploadConfig"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 入库仓库设置 -->
                <Tab text="入库仓库设置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="入库仓库设置（上传垛码关联数据时传入仓库编号）"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1F2937;
                                          -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="仓库编号（warehouseNo）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                              -fx-font-family: 'Microsoft YaHei';"
                                       minWidth="200"/>
                                <TextField fx:id="warehouseNoField"
                                           text="001"
                                           prefWidth="160"
                                           styleClass="text-field"
                                           promptText="如 001"/>
                            </HBox>

                            <Label text="说明：上传垛码关联数据至开放平台时，将该仓库编号作为入参 warehouseno 传入，默认值为 001。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <Button text="保存" mnemonicParsing="false"
                                    styleClass="primary-button, sw2-settings-save-btn"
                                    onAction="#onSaveWarehouseNo"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </Tab>

        <!-- ============ Tab2：页面配置（对齐设计稿 Yq73e / X7LKc：表格→说明→保存） ============ -->
        <Tab text="页面配置">
            <VBox spacing="0" style="-fx-background-color: white;" VBox.vgrow="ALWAYS">
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
                            style="-fx-background-color: white; -fx-border-width: 0; -fx-padding: 0;">
                    <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: white;">
                        <!-- 页面列表表格：圆角边框 + 表头 44 / 数据行 48 -->
                        <VBox spacing="0" styleClass="sw2-page-config-table">
                            <HBox alignment="CENTER_LEFT" minHeight="44" prefHeight="44" maxHeight="44"
                                  style="-fx-background-color: #F3F4F6; -fx-background-radius: 8 8 0 0;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="页面名称"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                                  -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="功能说明"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                                  -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER"
                                      style="-fx-padding: 0 16;">
                                    <Label text="显示"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                                  -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                            </HBox>

                            <!-- 行1：数据采集（必选） -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="数据采集（盒箱垛）"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="主界面，盒箱垛关联数据采集（必选，不可关闭）"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <!-- 必选行：非 ToggleButton，仅静态「开+置灰」Switch，避免可点、避免皮肤盖掉 graphic -->
                                    <StackPane fx:id="pageDataCollectionLockedSwitchHost"
                                               styleClass="sw2-page-config-locked-switch-host"
                                               alignment="CENTER"
                                               minWidth="48" prefWidth="48" maxWidth="48"
                                               minHeight="24" prefHeight="24" maxHeight="24"
                                               mouseTransparent="true"/>
                                </HBox>
                            </HBox>

                            <!-- 行2：手工采集 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="手工采集"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="扫码枪手工采集，相机损坏时替代"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pageManualToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>

                            <!-- 行3：数据查询 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="数据查询"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="查询采集关联数据"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pageQueryToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>

                            <!-- 行4：数据替换 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="数据替换"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="码替换操作"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pageReplaceToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>

                            <!-- 行5：生产统计 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="生产统计"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="生产统计报表"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pageStatsToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>

                            <!-- 行6：码包管理 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="码包管理"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="码包导入与管理"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pagePackageToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>

                            <!-- 行7：取消关联 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-border-color: transparent transparent #E5E7EB transparent;
                                         -fx-border-width: 0 0 1 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="取消关联"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="单个/批量取消关联"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pageCancelToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>

                            <!-- 行8：数据上传 -->
                            <HBox alignment="CENTER_LEFT" minHeight="48" prefHeight="48"
                                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 0 0 8 8;
                                         -fx-border-width: 0;">
                                <HBox minWidth="200" maxWidth="200" prefWidth="200" alignment="CENTER_LEFT"
                                      style="-fx-padding: 0 0 0 16;">
                                    <Label text="数据上传"
                                           style="-fx-font-size: 14px; -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
                                    <Label text="手动上传、上传状态查询"
                                           style="-fx-font-size: 14px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                           wrapText="true"/>
                                </HBox>
                                <HBox minWidth="100" maxWidth="100" prefWidth="100" alignment="CENTER" style="-fx-padding: 0 16;">
                                    <ToggleButton fx:id="pageUploadToggle" text="" selected="true"
                                                  styleClass="sw2-page-toggle-switch"
                                                  onAction="#onPageToggleChanged"/>
                                </HBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="· 控制主界面 Tab 栏显示，开启则显示、关闭则隐藏"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>
                            <Label text="· 列表中开启页面的顺序即为 Tab 栏显示顺序"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>
                            <Label text="· 配置保存后生效"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>
                        </VBox>

                        <Region minHeight="20" prefHeight="20" maxHeight="20"/>

                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <Button fx:id="savePageConfigBtn" text="保存" mnemonicParsing="false"
                                    styleClass="primary-button, sw2-settings-save-btn"
                                    onAction="#onSavePageConfig"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- ============ Tab3：设备 ============ -->
        <Tab text="设备">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     VBox.vgrow="ALWAYS"
                     maxHeight="Infinity" maxWidth="Infinity"
                     styleClass="sw2-settings-inner-tab-pane">

                <!-- IO设备管理（布局与致美斋 SystemConfig IO 表一致：撑满 Tab、列约束拉伸） -->
                <Tab text="IO设备管理">
                    <VBox spacing="0" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity"
                          minHeight="0" style="-fx-background-color: white;">
                        <!-- 工具栏 -->
                        <HBox spacing="10" styleClass="tool-bar" alignment="CENTER_LEFT">
                            <Button text="+ 添加设备" styleClass="primary-button"
                                    onAction="#onAddIoDevice"/>
                            <Button text="测试所有设备" styleClass="secondary-button"
                                    onAction="#onTestAllDevices"/>
                        </HBox>
                        <!-- 设备列表 -->
                        <TableView fx:id="ioDeviceTable"
                                   VBox.vgrow="ALWAYS"
                                   maxWidth="Infinity" minWidth="0" minHeight="0"
                                   styleClass="table-view sw2-settings-io-device-table">
                            <columns>
                                <TableColumn fx:id="deviceNameCol" text="设备名称" prefWidth="150" minWidth="80"/>
                                <TableColumn fx:id="deviceTypeCol" text="设备类型" prefWidth="120" minWidth="70"/>
                                <TableColumn fx:id="deviceAddrCol" text="连接地址" prefWidth="200" minWidth="100"/>
                                <TableColumn fx:id="devicePortCol" text="端口" prefWidth="90" minWidth="60"/>
                                <TableColumn fx:id="deviceStatusCol" text="状态" prefWidth="100" minWidth="80"/>
                                <TableColumn fx:id="deviceActionCol" text="操作" prefWidth="200" minWidth="180"/>
                            </columns>
                            <placeholder>
                                <Label text="暂无设备配置，点击「+ 添加设备」按钮添加"
                                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
                            </placeholder>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- 设备控制配置 -->
                <Tab text="设备控制配置">
                    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">
                        <VBox spacing="12" style="-fx-padding: 20px 24px;">

                            <!-- 剔除装置 -->
                            <Label text="剔除装置"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"/>
                            <Separator style="-fx-background-color: #E5E7EB;"/>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="触发剔除延时（ms）："
                                       minWidth="160"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="rejectTriggerDelayField"
                                           promptText="1000"
                                           prefWidth="120"
                                           styleClass="text-field"/>
                                <Label text="检测到需要剔除后，等待该时间再发送信号"
                                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="剔除收回时间（ms）："
                                       minWidth="160"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="rejectRetractTimeField"
                                           promptText="600"
                                           prefWidth="120"
                                           styleClass="text-field"/>
                                <Label text="发送剔除信号后，等待该时间自动发送收回信号"
                                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox>
                                <Button text="保存" mnemonicParsing="false"
                                        styleClass="primary-button, sw2-settings-save-btn"
                                        onAction="#onSaveDeviceSignalConfig"/>
                            </HBox>

                            <!-- 盒箱相机采集间隔 -->
                            <Label text="盒箱相机采集间隔"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"/>
                            <Separator style="-fx-background-color: #E5E7EB;"/>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="双相机等待超时（ms）："
                                       minWidth="160"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="boxCaseCameraMatchWaitTimeoutField"
                                           promptText="3000"
                                           prefWidth="120"
                                           styleClass="text-field"/>
                                <Label text="一侧收到批数据后，等待另一侧同批号的最长时间；0 表示不启用超时剔除"
                                       style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox>
                                <Button text="保存" mnemonicParsing="false"
                                        styleClass="primary-button, sw2-settings-save-btn"
                                        onAction="#onSaveBoxCaseCameraCaptureConfig"/>
                            </HBox>

                            <!-- 隐藏的信号字段（保留供控制器注入，不在界面显示） -->
                            <VBox managed="false" visible="false">
                                <TextField fx:id="cmdAllOffField"/>
                                <TextField fx:id="cmdNormalOnField"/>
                                <TextField fx:id="cmdNormalWithRejectField"/>
                                <TextField fx:id="cmdUploadSuccessField"/>
                                <TextField fx:id="cmdUploadSuccessWithRejectField"/>
                                <TextField fx:id="cmdUploadFailField"/>
                                <TextField fx:id="cmdUploadFailWithRejectField"/>
                                <TextField fx:id="alarmOpenHexField"/>
                                <TextField fx:id="alarmCloseHexField"/>
                                <TextField fx:id="alarmLightOnHexField"/>
                                <TextField fx:id="alarmLightOffHexField"/>
                                <TextField fx:id="rejectTriggerHexField"/>
                                <TextField fx:id="rejectRetractHexField"/>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </Tab>

        <!-- ============ Tab4：连接 ============ -->
        <Tab text="连接">
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     styleClass="sw2-settings-inner-tab-pane">

                <!-- 数据库连接（本机 + 1号机合并） -->
                <Tab text="数据库连接">
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
                        <VBox spacing="14" style="-fx-padding: 20px 24px;">

                            <!-- 本机数据库 section header -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="本机数据库（2号机自身）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"/>
                                <Label text="MySQL"
                                       style="-fx-background-color: #D1FAE5; -fx-text-fill: #065F46;
                                              -fx-background-radius: 20px; -fx-padding: 2px 10px;
                                              -fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="IP地址："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbHostField"
                                           prefWidth="220" styleClass="text-field"
                                           promptText="localhost"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="端口："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbPortField"
                                           prefWidth="120" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="数据库名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbNameField"
                                           prefWidth="220" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="用户名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="dbUserField"
                                           prefWidth="160" styleClass="text-field"/>
                                <Label text="密码："
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <PasswordField fx:id="dbPasswordField"
                                               prefWidth="160" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button text="保存本机配置" mnemonicParsing="false"
                                        styleClass="primary-button, sw2-settings-save-btn"
                                        onAction="#onSaveDbConfig"/>
                                <Button text="连接测试"
                                        styleClass="secondary-button"
                                        onAction="#onTestDbConnection"/>
                                <HBox fx:id="dbTestResultRow" spacing="6" alignment="CENTER_LEFT" visible="false" managed="false">
                                    <StackPane fx:id="dbTestResultIconPane" minWidth="16" minHeight="16" prefWidth="16" prefHeight="16"
                                               maxWidth="16" maxHeight="16"/>
                                    <Label fx:id="dbTestResultLabel"
                                           text=""
                                           style="-fx-font-size: 13px; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                            </HBox>

                            <Separator style="-fx-background-color: #E5E7EB; -fx-padding: 4px 0;"/>

                            <!-- 1号机数据库 section header -->
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="1号机数据库（轮询同步源）"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                              -fx-font-family: 'Microsoft YaHei';"/>
                                <Label text="SQLServer"
                                       style="-fx-background-color: #DBEAFE; -fx-text-fill: #1E40AF;
                                              -fx-background-radius: 20px; -fx-padding: 2px 10px;
                                              -fx-font-size: 13px; -fx-font-weight: bold; -fx-font-family: 'Microsoft YaHei';"/>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="IP地址："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbHostField"
                                           prefWidth="220" styleClass="text-field"
                                           promptText="192.168.1.xxx"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="端口："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbPortField"
                                           prefWidth="120" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="数据库名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbNameField"
                                           prefWidth="220" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="表名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbTableField"
                                           prefWidth="220" styleClass="text-field"
                                           promptText="默认 T_Code"/>
                            </HBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="用户名："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="m1DbUserField"
                                           prefWidth="160" styleClass="text-field"/>
                                <Label text="密码："
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <PasswordField fx:id="m1DbPasswordField"
                                               prefWidth="160" styleClass="text-field"/>
                            </HBox>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button text="保存1号机配置" mnemonicParsing="false"
                                        styleClass="primary-button, sw2-settings-save-btn"
                                        onAction="#onSaveM1DbConfig"/>
                                <Button text="连接测试"
                                        styleClass="secondary-button"
                                        onAction="#onTestM1DbConnection"/>
                                <HBox fx:id="m1DbTestResultRow" spacing="6" alignment="CENTER_LEFT" visible="false" managed="false">
                                    <StackPane fx:id="m1DbTestResultIconPane" minWidth="16" minHeight="16" prefWidth="16" prefHeight="16"
                                               maxWidth="16" maxHeight="16"/>
                                    <Label fx:id="m1DbTestResultLabel"
                                           text=""
                                           style="-fx-font-size: 13px; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                            </HBox>

                            <!-- 隐藏的初始同步游标字段，保留供控制器注入 -->
                            <TextField fx:id="m1InitialSerialNoField" managed="false" visible="false"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- 接口服务（原"后端服务地址"） -->
                <Tab text="接口服务">
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
                        <VBox spacing="16" style="-fx-padding: 20px 24px;">
                            <Label text="接口地址配置"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;
                                          -fx-font-family: 'Microsoft YaHei';"/>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="接口地址："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="backendBaseUrlField"
                                           HBox.hgrow="ALWAYS" maxWidth="400"
                                           styleClass="text-field"
                                           promptText="http://example.com/api"/>
                            </HBox>

                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <Label text="开放平台："
                                       minWidth="90" alignment="CENTER_RIGHT"
                                       style="-fx-font-size: 14px; -fx-text-fill: #374151; -fx-font-family: 'Microsoft YaHei';"/>
                                <TextField fx:id="openPlatformUrlField"
                                           HBox.hgrow="ALWAYS" maxWidth="400"
                                           styleClass="text-field"
                                           promptText="请输入开放平台地址"/>
                            </HBox>

                            <Label text="说明：配置修改后保存生效；接口地址需包含完整路径，开放平台为第三方授权地址。"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-family: 'Microsoft YaHei';"
                                   wrapText="true"/>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button text="保存" mnemonicParsing="false"
                                        styleClass="primary-button, sw2-settings-save-btn"
                                        onAction="#onSaveBackendBaseUrl"/>
                                <HBox fx:id="backendBaseUrlResultRow" spacing="6" alignment="CENTER_LEFT" visible="false" managed="false">
                                    <StackPane fx:id="backendBaseUrlResultIconPane" minWidth="16" minHeight="16" prefWidth="16" prefHeight="16"
                                               maxWidth="16" maxHeight="16"/>
                                    <Label fx:id="backendBaseUrlResultLabel"
                                           text=""
                                           style="-fx-font-size: 13px; -fx-font-family: 'Microsoft YaHei';"/>
                                </HBox>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </Tab>

    </TabPane>

</VBox>