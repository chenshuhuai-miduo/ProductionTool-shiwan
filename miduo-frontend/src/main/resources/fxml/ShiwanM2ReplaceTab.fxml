<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 数据替换 Tab -->
<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2ReplaceController"
      styleClass="sw2-tab-content" spacing="12"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <!-- ——— 左侧表单（480px）——— -->
    <VBox prefWidth="480" minWidth="480" maxWidth="480">
        <VBox styleClass="shiwan-m2-card" spacing="16">
            <Label text="码替换" styleClass="sw2-section-title"/>

            <!-- 原码 -->
            <VBox spacing="6">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="* " styleClass="sw2-required" style="-fx-font-weight:bold;"/>
                    <Label text="原码" styleClass="sw2-field-label"/>
                    <Button text="?" styleClass="shiwan-m2-help-btn"
                            onAction="#onOrigCodeHelp"/>
                </HBox>
                <TextField fx:id="origCodeField"
                           promptText="请输入或扫描原码（待替换的码）"
                           styleClass="sw2-field-input"/>
            </VBox>

            <!-- 新码 -->
            <VBox spacing="6">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="* " styleClass="sw2-required" style="-fx-font-weight:bold;"/>
                    <Label text="新码" styleClass="sw2-field-label"/>
                    <Button text="?" styleClass="shiwan-m2-help-btn"
                            onAction="#onNewCodeHelp"/>
                </HBox>
                <TextField fx:id="newCodeField"
                           promptText="请输入或扫描新码（替换后的码）"
                           styleClass="sw2-field-input"/>
            </VBox>

            <!-- 替换原因 -->
            <VBox spacing="6">
                <Label text="替换原因" styleClass="sw2-field-label"/>
                <TextArea fx:id="reasonField"
                          promptText="请输入替换原因（如：码损坏、码错误等）"
                          styleClass="sw2-field-textarea"
                          prefRowCount="3" wrapText="true"/>
            </VBox>

            <!-- 警告 -->
            <Label text="⚠ 替换操作不可恢复，请确认码值无误后再执行替换。"
                   styleClass="sw2-warn-label" maxWidth="Infinity" wrapText="true"/>

            <!-- 操作按钮 -->
            <HBox spacing="12">
                <Button text="清空" styleClass="sw2-btn-secondary"
                        onAction="#onClear"
                        minHeight="48" prefHeight="48"
                        style="-fx-min-width:80px; -fx-font-size:15px;"/>
                <Button text="确认替换" styleClass="sw2-btn-primary"
                        onAction="#onConfirmReplace"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        minHeight="48" prefHeight="48" style="-fx-font-size:15px;"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- ——— 右侧结果区（flex）——— -->
    <VBox HBox.hgrow="ALWAYS" spacing="0" styleClass="shiwan-m2-card">
        <Label text="替换结果" styleClass="sw2-result-header"/>
        <ScrollPane fx:id="resultScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true"
                    style="-fx-background-color: #F9FAFB; -fx-background: #F9FAFB; -fx-border-width:0; -fx-padding:12px;">
            <VBox fx:id="resultContainer" spacing="10">
                <Label fx:id="emptyResultLabel"
                       text="暂无替换记录"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:15px; -fx-padding:40px 0;"
                       alignment="CENTER" maxWidth="Infinity"/>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
