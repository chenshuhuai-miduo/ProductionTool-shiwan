<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.RenewalSuccessController"
      styleClass="dialog-fullscreen" prefWidth="520"
      stylesheets="@../css/deviceVerification-style.css">

    <!-- 对话框头部 -->
    <HBox styleClass="dialog-header-flat" alignment="CENTER_LEFT">
        <Label text="续期成功" styleClass="dialog-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" styleClass="dialog-close-btn" onAction="#handleConfirm"/>
    </HBox>

    <!-- 对话框主体 -->
    <VBox styleClass="dialog-body-center" spacing="24" alignment="CENTER" VBox.vgrow="ALWAYS">

        <!-- 成功图标 -->
        <VBox alignment="CENTER" spacing="12">
            <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                <image>
                    <Image url="@/icons/成功.png"/>
                </image>
            </ImageView>
            <Label text="续期成功！" styleClass="success-title"/>
        </VBox>

        <!-- 信息卡片 -->
        <VBox styleClass="info-card-flat" spacing="12" maxWidth="380">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="新到期时间" styleClass="info-label-flat"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="newExpirationLabel" text="2027-12-02" styleClass="info-value-flat"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="延长天数" styleClass="info-label-flat"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="extensionDaysLabel" text="+365天" styleClass="info-value-flat"/>
            </HBox>
        </VBox>
    </VBox>

    <!-- 对话框底部 -->
    <HBox alignment="CENTER" styleClass="dialog-footer-center">
        <Button fx:id="confirmButton" text="开始使用" onAction="#handleConfirm" styleClass="btn, btn-primary" prefWidth="200"/>
    </HBox>

</VBox>
