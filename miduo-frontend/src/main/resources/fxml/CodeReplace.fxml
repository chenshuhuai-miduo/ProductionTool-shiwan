<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.CodeReplaceController"
      prefWidth="600" prefHeight="550" styleClass="application-background"
      stylesheets="@../css/base-styles.css">
   
   <padding>
      <Insets top="20" right="20" bottom="10" left="20"/>
   </padding>
   
   <!-- 居中容器 -->
   <HBox VBox.vgrow="ALWAYS" alignment="CENTER">
      <!-- 码替换表单 -->
      <VBox spacing="20" alignment="CENTER" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1px; -fx-padding: 30px; -fx-pref-width: 500px;">
         
         <Label text="码替换" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
         
         <!-- 原码输入 -->
         <VBox spacing="5" prefWidth="440">
            <Label text="原码 *" style="-fx-font-size: 12px; -fx-text-fill: #333;">
               <graphic>
                  <Label text="*" style="-fx-text-fill: red; -fx-font-size: 12px;"/>
               </graphic>
            </Label>
            <TextField fx:id="originalCodeField" promptText="请输入或扫描原码" styleClass="text-field" prefHeight="35"/>
         </VBox>
         
         <!-- 新码输入 -->
         <VBox spacing="5" prefWidth="440">
            <Label text="新码 *" style="-fx-font-size: 12px; -fx-text-fill: #333;">
               <graphic>
                  <Label text="*" style="-fx-text-fill: red; -fx-font-size: 12px;"/>
               </graphic>
            </Label>
            <TextField fx:id="newCodeField" promptText="请输入或扫描新码" styleClass="text-field" prefHeight="35"/>
         </VBox>
         
         <!-- 替换原因输入 -->
         <VBox spacing="5" prefWidth="440">
            <Label text="替换原因（可选）" style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
            <TextArea fx:id="reasonTextArea" promptText="请输入替换原因" prefRowCount="3" wrapText="true" styleClass="text-area"/>
         </VBox>
         
         <!-- 操作按钮 -->
         <HBox spacing="15" alignment="CENTER">
            <Button text="清空" styleClass="secondary-button" onAction="#onClear" prefWidth="120" prefHeight="35"/>
            <Button text="确认替换" styleClass="primary-button" onAction="#onConfirmReplace" prefWidth="120" prefHeight="35"/>
         </HBox>
         
         <!-- 警告信息 -->
         <Label text="替换操作不可恢复，请确认码值无误后再执行替换。" 
                wrapText="true" 
                style="-fx-font-size: 11px; -fx-text-fill: #d32f2f; -fx-max-width: 440px;"/>
      </VBox>
   </HBox>
   
   <!-- 底部状态栏 -->
   <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 10px; -fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-width: 1px 0 0 0; -fx-min-height: 35px;">
      <Region HBox.hgrow="ALWAYS"/>
      
      <Label fx:id="currentTimeLabel" text="2024-12-01 10:00:00" style="-fx-font-size: 11px;"/>
   </HBox>
</VBox>

