<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!-- 系统密码输入弹窗 - 无原生标题栏，整体可拖拽 -->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2PasswordDialogController"
      fx:id="rootBox"
      prefWidth="400"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color: white;
             -fx-background-radius: 16;
             -fx-border-color: #E5E7EB;
             -fx-border-radius: 16;
             -fx-border-width: 1;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 24, 0, 0, 6);">

    <!-- 内容区 padding: 40 32 32 32, gap 24 -->
    <VBox spacing="24" style="-fx-padding: 40 32 32 32;">

        <!-- 标题行：锁图标 + 文字，居中 -->
        <VBox spacing="12" alignment="CENTER">
            <HBox alignment="CENTER" spacing="10">
                <Label text="&#x1F512;"
                       style="-fx-font-family: 'Segoe UI Emoji'; -fx-font-size: 22px;"/>
                <Label text="请输入系统密码"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;
                              -fx-text-fill: #1F2937; -fx-font-family: 'Microsoft YaHei';"/>
            </HBox>
            <!-- 副标题 -->
            <Label text="此操作受密码保护，请输入系统管理密码以确认操作。"
                   wrapText="true" alignment="CENTER" maxWidth="336"
                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280;
                          -fx-font-family: 'Microsoft YaHei'; -fx-alignment: CENTER;"/>
        </VBox>

        <!-- 密码输入框区（PasswordField + 眼睛按钮 叠加） -->
        <StackPane>
            <PasswordField fx:id="passwordField"
                           promptText="请输入密码"
                           style="-fx-min-height: 52px; -fx-pref-height: 52px;
                                  -fx-font-size: 18px; -fx-text-fill: #374151;
                                  -fx-background-color: white;
                                  -fx-background-radius: 10;
                                  -fx-border-color: #D1D5DB; -fx-border-radius: 10;
                                  -fx-border-width: 1.5; -fx-padding: 0 48 0 14;
                                  -fx-font-family: 'Microsoft YaHei';"/>
            <TextField fx:id="plainField"
                       promptText="请输入密码"
                       visible="false" managed="false"
                       style="-fx-min-height: 52px; -fx-pref-height: 52px;
                              -fx-font-size: 18px; -fx-text-fill: #374151;
                              -fx-background-color: white;
                              -fx-background-radius: 10;
                              -fx-border-color: #D1D5DB; -fx-border-radius: 10;
                              -fx-border-width: 1.5; -fx-padding: 0 48 0 14;
                              -fx-font-family: 'Microsoft YaHei';"/>
            <!-- 眼睛切换按钮，右对齐 -->
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 12 0 0;" pickOnBounds="false">
                <Button fx:id="eyeBtn" onAction="#onToggleVisible"
                        style="-fx-background-color: transparent; -fx-border-width: 0;
                               -fx-cursor: hand; -fx-effect: null;
                               -fx-min-width: 28; -fx-min-height: 28; -fx-padding: 0;">
                    <!-- 眼睛图标使用文字符号 -->
                    <graphic>
                        <Label fx:id="eyeIcon" text="&#128065;"
                               style="-fx-font-size: 16px; -fx-text-fill: #9CA3AF;"/>
                    </graphic>
                </Button>
            </HBox>
        </StackPane>

        <!-- 错误提示 -->
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #DC2626; -fx-font-size: 13px;
                      -fx-font-family: 'Microsoft YaHei';"
               managed="false" visible="false"/>

        <!-- 底部按钮 -->
        <HBox alignment="CENTER" spacing="12">
            <Button text="取消" onAction="#onCancel"
                    style="-fx-pref-width: 110px; -fx-min-height: 44px;
                           -fx-background-color: #6B7280; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-border-width: 0;
                           -fx-cursor: hand; -fx-effect: null;
                           -fx-font-family: 'Microsoft YaHei';"/>
            <Button text="确认" onAction="#onConfirm"
                    style="-fx-pref-width: 110px; -fx-min-height: 44px;
                           -fx-background-color: #2563EB; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-border-width: 0;
                           -fx-cursor: hand; -fx-effect: null;
                           -fx-font-family: 'Microsoft YaHei';"/>
        </HBox>
    </VBox>
</VBox>
