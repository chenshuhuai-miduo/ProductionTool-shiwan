<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2DataReplaceController"
      styleClass="shiwan-m2-content-body" spacing="12">

    <VBox prefWidth="500" minWidth="460" spacing="12" styleClass="shiwan-m2-maint-card">
        <Label text="码替换" styleClass="shiwan-m2-maint-title"/>

        <VBox spacing="6">
            <Label text="*原码" styleClass="shiwan-m2-maint-label"/>
            <TextField fx:id="originalCodeField"
                       promptText="请输入或扫描原码（待替换的码）"
                       styleClass="shiwan-m2-maint-input"/>
        </VBox>

        <VBox spacing="6">
            <Label text="*新码" styleClass="shiwan-m2-maint-label"/>
            <TextField fx:id="newCodeField"
                       promptText="请输入或扫描新码（替换后的码）"
                       styleClass="shiwan-m2-maint-input"/>
        </VBox>

        <VBox spacing="6">
            <Label text="替换原因" styleClass="shiwan-m2-maint-label"/>
            <TextArea fx:id="reasonTextArea"
                      prefRowCount="3"
                      wrapText="true"
                      promptText="请输入替换原因（如：码损坏、码错误等）"
                      styleClass="shiwan-m2-maint-text-area"/>
        </VBox>

        <Label text="替换操作不可恢复，请确认码值无误后再执行替换。"
               styleClass="shiwan-m2-maint-warning"/>

        <HBox spacing="12">
            <Button text="清空"
                    styleClass="shiwan-m2-maint-btn-secondary"
                    onAction="#onClearReplaceForm"/>
            <Button text="确认替换"
                    styleClass="shiwan-m2-maint-btn-primary"
                    onAction="#onConfirmReplace"/>
        </HBox>

        <Label fx:id="replaceStatusLabel" styleClass="shiwan-m2-maint-hint"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="shiwan-m2-maint-card">
        <Label text="替换结果" styleClass="shiwan-m2-maint-title"/>
        <ListView fx:id="replaceResultList"
                  VBox.vgrow="ALWAYS"
                  styleClass="shiwan-m2-maint-result-list"/>
        <padding>
            <Insets top="0" right="0" bottom="0" left="0"/>
        </padding>
    </VBox>
</HBox>
