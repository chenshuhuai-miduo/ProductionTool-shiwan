<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 数据替换（主窗口内嵌 Tab） -->
<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2DataReplaceController"
      styleClass="sw2-tab-content" spacing="16"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <!-- ——— 左侧表单（500px）——— -->
    <VBox prefWidth="500" minWidth="500" maxWidth="500" spacing="20"
          style="-fx-background-color:white; -fx-border-color:#D9E1EC; -fx-border-radius:12; -fx-background-radius:12; -fx-border-width:1; -fx-padding:24;">

        <Label text="码替换" styleClass="sw2-result-header"
               style="-fx-font-size:24px; -fx-padding:0 0 8px 0;"/>

        <!-- 原码 -->
        <VBox spacing="6">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="*" styleClass="sw2-result-header"
                       style="-fx-font-size:18px; -fx-border-width:0; -fx-padding:0; -fx-text-fill:#EF4444;"/>
                <Label text="原码" styleClass="sw2-result-header"
                       style="-fx-font-size:18px; -fx-border-width:0; -fx-padding:0; -fx-text-fill:#1F2937;"/>
                <Button fx:id="origHelpButton" onAction="#onOrigCodeHelp" styleClass="shiwan-m2-help-btn"/>
            </HBox>
            <TextField fx:id="origCodeField"
                       promptText="请输入或扫描原码（待替换的码）"
                       styleClass="sw2-field-input"
                       minHeight="48" prefHeight="48"/>
        </VBox>

        <!-- 新码 -->
        <VBox spacing="6">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="*" styleClass="sw2-result-header"
                       style="-fx-font-size:18px; -fx-border-width:0; -fx-padding:0; -fx-text-fill:#EF4444;"/>
                <Label text="新码" styleClass="sw2-result-header"
                       style="-fx-font-size:18px; -fx-border-width:0; -fx-padding:0; -fx-text-fill:#1F2937;"/>
                <Button fx:id="newHelpButton" onAction="#onNewCodeHelp" styleClass="shiwan-m2-help-btn"/>
            </HBox>
            <TextField fx:id="newCodeField"
                       promptText="请输入或扫描新码（替换后的码）"
                       styleClass="sw2-field-input"
                       minHeight="48" prefHeight="48"/>
        </VBox>

        <!-- 替换原因 -->
        <VBox spacing="6">
            <Label text="替换原因" styleClass="sw2-result-header"
                   style="-fx-font-size:18px; -fx-border-width:0; -fx-padding:0; -fx-text-fill:#374151;"/>
            <TextArea fx:id="reasonField"
                      promptText="请输入替换原因（如：码损坏、码错误等）"
                      styleClass="sw2-field-textarea"
                      prefHeight="80" prefRowCount="2" wrapText="true"/>
        </VBox>

        <!-- 警告 -->
        <Label text="替换操作不可恢复，请确认码值无误后再执行替换。"
               styleClass="sw2-result-header"
               style="-fx-font-size:18px; -fx-text-fill:#EF4444; -fx-border-width:0; -fx-padding:0;"
               maxWidth="Infinity" wrapText="true"/>

        <!-- 操作按钮 -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="清空" onAction="#onClearReplaceForm"
                    minWidth="80" prefWidth="80" minHeight="48" prefHeight="48"
                    style="-fx-font-size:18px; -fx-font-weight:bold; -fx-font-family:'Microsoft YaHei';
                           -fx-background-color:#6B7280; -fx-text-fill:white;
                           -fx-background-radius:8; -fx-border-width:0; -fx-effect:null; -fx-cursor:hand;"/>
            <Button text="确认替换" onAction="#onConfirmReplace"
                    minWidth="120" prefWidth="120" minHeight="48" prefHeight="48"
                    style="-fx-font-size:18px; -fx-font-weight:bold; -fx-font-family:'Microsoft YaHei';
                           -fx-background-color:#2563EB; -fx-text-fill:white;
                           -fx-background-radius:8; -fx-border-width:0; -fx-effect:null; -fx-cursor:hand;"/>
        </HBox>
    </VBox>

    <!-- ——— 右侧结果区（flex）——— -->
    <VBox HBox.hgrow="ALWAYS" spacing="16"
          style="-fx-background-color:white; -fx-border-color:#D9E1EC; -fx-border-radius:12; -fx-background-radius:12; -fx-border-width:1; -fx-padding:24;">

        <Label text="替换结果" styleClass="sw2-result-header"
               style="-fx-font-size:24px; -fx-padding:0 0 8px 0;"/>

        <ScrollPane fx:id="resultScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true"
                    style="-fx-background-color:#F9FAFB; -fx-background:#F9FAFB;
                           -fx-border-color:#E5E7EB; -fx-border-radius:8;
                           -fx-background-radius:8; -fx-border-width:1; -fx-padding:20;">
            <VBox fx:id="resultContainer" spacing="20">
                <Label fx:id="emptyResultLabel"
                       text="暂无替换记录"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:16px; -fx-padding:40 0;"
                       alignment="CENTER" maxWidth="Infinity"/>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
