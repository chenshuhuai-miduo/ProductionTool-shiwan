<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2CancelAssociationController"
      styleClass="shiwan-m2-content-body" spacing="16">

    <!-- ===== 左侧操作区（600px）===== -->
    <VBox prefWidth="600" minWidth="540" spacing="12" styleClass="shiwan-m2-maint-card">

        <!-- 标题 + 帮助按钮（紧跟标题后） -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="取消关联" styleClass="shiwan-m2-maint-title"/>
            <Button text="?" onAction="#onShowHelp" styleClass="shiwan-m2-help-btn"/>
        </HBox>

        <!-- 码输入 -->
        <VBox spacing="6">
            <HBox spacing="2" alignment="CENTER_LEFT">
                <Label text="*" style="-fx-text-fill:#EF4444; -fx-font-size:18px; -fx-font-weight:bold;"/>
                <Label text="码（盒/箱/垛，支持扫瓶码）" styleClass="shiwan-m2-maint-label"/>
            </HBox>
            <HBox spacing="12">
                <TextField fx:id="codeInputField"
                           HBox.hgrow="ALWAYS"
                           promptText="请输入或扫描盒码、箱码、垛码（或瓶码）"
                           styleClass="shiwan-m2-maint-input"/>
                <Button fx:id="addToListButton" text="加入列表" styleClass="shiwan-m2-maint-btn-primary"
                        prefWidth="100" onAction="#onAddToList"/>
            </HBox>
        </VBox>

        <!-- 待取消列表 -->
        <VBox spacing="6">
            <Label text="待取消列表" styleClass="shiwan-m2-maint-label"/>
            <ListView fx:id="pendingList" prefHeight="120" maxHeight="160"
                      styleClass="shiwan-m2-maint-result-list"/>
        </VBox>

        <!-- 识别按钮 -->
        <Button text="识别" styleClass="shiwan-m2-maint-btn-primary"
                prefWidth="80" onAction="#onIdentify"/>

        <!-- 取消范围：用两个普通 Button 模拟单选效果 -->
        <VBox spacing="8">
            <Label text="取消范围" styleClass="shiwan-m2-maint-label"/>
            <HBox spacing="8">
                <Button fx:id="scopeOneBtn" text="" onAction="#onScopeOne"/>
                <Button fx:id="scopeAllBtn" text="" onAction="#onScopeAll"/>
            </HBox>
        </VBox>

        <!-- 分隔线 -->
        <Region prefHeight="1" maxHeight="1"
                style="-fx-background-color:#E5E7EB;"/>

        <!-- 警告文字 -->
        <Label text="⚠ 操作不可恢复，请确认后执行"
               style="-fx-text-fill:#EF4444; -fx-font-size:18px; -fx-font-weight:bold;"/>

        <!-- 操作按钮（居中） -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="清空列表" styleClass="shiwan-m2-maint-btn-secondary"
                    prefWidth="100" onAction="#onClearList"/>
            <Button fx:id="confirmCancelButton" text="确认取消关联"
                    styleClass="shiwan-m2-maint-btn-danger"
                    prefWidth="150" disable="true" onAction="#onConfirmCancel"/>
        </HBox>

    </VBox>

    <!-- ===== 右侧结果区 ===== -->
    <VBox HBox.hgrow="ALWAYS" spacing="16">

        <!-- 识别结果 -->
        <VBox VBox.vgrow="ALWAYS" spacing="8" styleClass="shiwan-m2-maint-card">
            <Label text="识别结果" styleClass="shiwan-m2-maint-title"/>
            <Label fx:id="identifySummaryLabel"
                   text=""
                   style="-fx-font-size:14px; -fx-text-fill:#9CA3AF;"/>
            <ListView fx:id="identifyResultList" VBox.vgrow="ALWAYS"
                      styleClass="shiwan-m2-maint-result-list"/>
        </VBox>

        <!-- 取消记录 -->
        <VBox prefHeight="220" minHeight="160" spacing="8" styleClass="shiwan-m2-maint-card">
            <Label text="取消记录"
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1F2937;"/>
            <ListView fx:id="cancelRecordList" VBox.vgrow="ALWAYS"
                      styleClass="shiwan-m2-maint-result-list"/>
        </VBox>

    </VBox>
</HBox>
