<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 码替换确认弹窗 -->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2ReplaceConfirmDialogController"
      prefWidth="500"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color: white; -fx-border-color: #D9E1EC; -fx-border-width: 1;">

    <!-- 自定义标题栏 -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT"
          style="-fx-background-color: #F5F7FA;
                 -fx-border-color: transparent transparent #E5E7EB transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 0 8 0 24;
                 -fx-min-height: 56; -fx-pref-height: 56;">
        <Label text="确认码替换"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1F2937; -fx-font-family:'Microsoft YaHei';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" onAction="#onCancel"
                style="-fx-background-color:transparent; -fx-text-fill:#9CA3AF; -fx-font-size:26px;
                       -fx-cursor:hand; -fx-min-width:44; -fx-min-height:44;
                       -fx-border-width:0; -fx-background-radius:6; -fx-effect:null; -fx-padding:0;"/>
    </HBox>

    <!-- 内容区 -->
    <VBox spacing="16" style="-fx-padding: 24 28 20 28;">

        <!-- 确认提示标题 -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="⚠" style="-fx-font-size:20px; -fx-text-fill:#DC2626;"/>
            <Label text="请确认替换信息："
                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1F2937;"/>
        </HBox>

        <!-- 替换信息展示框 -->
        <VBox fx:id="infoBox" spacing="8"
              style="-fx-background-color:#F9FAFB; -fx-background-radius:8;
                     -fx-border-color:#E5E7EB; -fx-border-radius:8; -fx-border-width:1;
                     -fx-padding:16;">
            <Label fx:id="origCodeLabel" text="原码值：—"
                   style="-fx-font-size:16px; -fx-text-fill:#374151;"/>
            <Label fx:id="newCodeLabel" text="新码值：—"
                   style="-fx-font-size:16px; -fx-text-fill:#374151;"/>
            <Label fx:id="reasonLabel" text="替换原因：—"
                   style="-fx-font-size:16px; -fx-text-fill:#374151;"/>
        </VBox>

        <!-- 替换说明（小字） -->
        <Label fx:id="remarkLabel"
               text="ℹ 已上传的码关联将先替换云端再替换本地。盖码、箱码等有内码的类型，会同步替换云端内码。"
               style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-wrap-text:true;"
               wrapText="true" maxWidth="Infinity"/>

        <!-- 密码输入 -->
        <VBox spacing="6">
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="*" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#DC2626;"/>
                <Label text="请输入密码" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1F2937;"/>
            </HBox>
            <PasswordField fx:id="passwordField"
                           promptText="请输入密码"
                           style="-fx-font-size:18px; -fx-background-color:white;
                                  -fx-border-color:#D1D5DB; -fx-border-width:1;
                                  -fx-border-radius:6; -fx-background-radius:6;
                                  -fx-min-height:40px; -fx-padding:0 12;"/>
        </VBox>

        <!-- 错误提示 -->
        <Label fx:id="errorLabel" text=""
               style="-fx-font-size:14px; -fx-text-fill:#DC2626;"
               visible="false" managed="false"/>

        <!-- 底部警告 -->
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="⚠" style="-fx-font-size:16px; -fx-text-fill:#DC2626;"/>
            <Label text="此操作不可恢复，请仔细核对后确认！"
                   style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#DC2626;"/>
        </HBox>
    </VBox>

    <!-- 底部按钮 -->
    <HBox alignment="CENTER" spacing="12"
          style="-fx-padding: 0 28 24 28;">
        <Button text="取消" onAction="#onCancel"
                style="-fx-min-width:80px; -fx-pref-width:80px; -fx-min-height:40px; -fx-pref-height:40px;
                       -fx-font-size:18px; -fx-background-color:#F3F4F6; -fx-text-fill:#374151;
                       -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:8; -fx-border-radius:8;
                       -fx-cursor:hand;"/>
        <Button text="确认替换" onAction="#onConfirm"
                style="-fx-min-width:120px; -fx-pref-width:120px; -fx-min-height:40px; -fx-pref-height:40px;
                       -fx-font-size:18px; -fx-font-weight:bold;
                       -fx-background-color:#DC2626; -fx-text-fill:white;
                       -fx-background-radius:8; -fx-border-width:0; -fx-cursor:hand;"/>
    </HBox>
</VBox>
