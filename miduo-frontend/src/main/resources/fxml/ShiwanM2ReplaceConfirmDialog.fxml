<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 码替换确认弹窗 -->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2ReplaceConfirmDialogController"
      prefWidth="520"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color: white; -fx-border-color: #D9E1EC; -fx-border-width: 1;">

    <!-- 自定义标题栏 -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT"
          style="-fx-background-color: #F5F7FA;
                 -fx-border-color: transparent transparent #E5E7EB transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-padding: 0 8 0 24;
                 -fx-min-height: 56; -fx-pref-height: 56;">
        <Label text="数据替换"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1F2937; -fx-font-family:'Microsoft YaHei';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" onAction="#onCancel" styleClass="sw2-dialog-title-close-btn"/>
    </HBox>

    <!-- 内容区 -->
    <VBox spacing="16" style="-fx-padding: 20 24 24 24;">

        <!-- 确认提示标题 -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <StackPane fx:id="headerWarnIconPane" minWidth="20" minHeight="20" prefWidth="20" prefHeight="20"
                       maxWidth="20" maxHeight="20"/>
            <Label text="请确认替换信息："
                   style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#991B1B; -fx-font-family:'Microsoft YaHei';"/>
        </HBox>

        <!-- 替换信息展示框 -->
        <VBox fx:id="infoBox" spacing="10"
              style="-fx-background-color:#F9FAFB; -fx-background-radius:8;
                     -fx-border-color:#E5E7EB; -fx-border-radius:8; -fx-border-width:1;
                     -fx-padding: 14 16;">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="原码值："
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                <Label fx:id="origCodeValue" text="—"
                       style="-fx-font-size:16px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="新码值："
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                <Label fx:id="newCodeValue" text="—"
                       style="-fx-font-size:16px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            </HBox>
            <HBox fx:id="reasonRow" spacing="8" alignment="CENTER_LEFT">
                <Label text="替换原因："
                       style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                <Label fx:id="reasonValue" text="—"
                       style="-fx-font-size:16px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
            </HBox>
        </VBox>

        <!-- 替换说明 -->
        <VBox spacing="4">
            <Label text="已上传的码关联将先替换云端再替换本地。"
                   style="-fx-font-size:16px; -fx-text-fill:#0369A1; -fx-font-family:'Microsoft YaHei';"/>
            <Label text="盖码、箱码等有内码的类型，会同步替换云端内码。"
                   style="-fx-font-size:16px; -fx-text-fill:#0369A1; -fx-font-family:'Microsoft YaHei';"/>
        </VBox>

        <!-- 底部警告 -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <StackPane fx:id="footerWarnIconPane" minWidth="18" minHeight="18" prefWidth="18" prefHeight="18"
                       maxWidth="18" maxHeight="18"/>
            <Label text="此操作不可恢复，请仔细核对后确认！"
                   style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#DC2626; -fx-font-family:'Microsoft YaHei';"/>
        </HBox>
    </VBox>

    <!-- 底部按钮区 -->
    <HBox alignment="CENTER" spacing="12"
          style="-fx-background-color:#F9FAFB;
                 -fx-border-color:#E5E7EB transparent transparent transparent;
                 -fx-border-width: 1 0 0 0;
                 -fx-min-height:72; -fx-pref-height:72;">
        <Button text="取消" onAction="#onCancel"
                style="-fx-min-width:90; -fx-pref-width:90; -fx-min-height:40; -fx-pref-height:40;
                       -fx-font-size:18px; -fx-font-weight:bold; -fx-background-color:#F3F4F6;
                       -fx-text-fill:#374151; -fx-background-radius:8; -fx-border-width:0;
                       -fx-cursor:hand; -fx-effect:null;"/>
        <Button text="确认替换" onAction="#onConfirm"
                style="-fx-min-width:104; -fx-pref-width:104; -fx-min-height:40; -fx-pref-height:40;
                       -fx-font-size:18px; -fx-font-weight:bold;
                       -fx-background-color:#EF4444; -fx-text-fill:white;
                       -fx-background-radius:8; -fx-border-width:0; -fx-cursor:hand; -fx-effect:null;"/>
    </HBox>
</VBox>
