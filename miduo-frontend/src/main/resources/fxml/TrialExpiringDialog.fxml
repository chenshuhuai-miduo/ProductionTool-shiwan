<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.TrialExpiringDialogController"
      styleClass="dialog-fullscreen">

    <!-- 场景1：剩余2-3天（警告样式） -->
    <VBox fx:id="sceneWarning" visible="true" managed="true" 
          styleClass="dialog-content" spacing="0" VBox.vgrow="ALWAYS">

        <!-- Header -->
        <HBox styleClass="dialog-header-flat" alignment="CENTER_LEFT">
            <Label text="试用即将到期" styleClass="dialog-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeButtonWarning" text="×" styleClass="dialog-close-btn"
                    onAction="#onLaterRemind"/>
        </HBox>

        <!-- Body -->
        <VBox styleClass="dialog-body-center" spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">
            <!-- 闹钟图标 -->
            <VBox alignment="CENTER" spacing="0">
                <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                    <image>
                        <Image url="@/icons/提示.png"/>
                    </image>
                </ImageView>
            </VBox>
            
            <!-- 标题文字：试用期即将到期，剩余 X 天 -->
            <HBox alignment="CENTER" spacing="0">
                <Label text="试用期即将到期，剩余 " styleClass="expiring-title-text"/>
                <Label fx:id="countdownBadgeWarning" text="3" styleClass="expiring-days-number"/>
                <Label text=" 天" styleClass="expiring-title-text"/>
            </HBox>

            <!-- Divider -->
            <HBox styleClass="divider-dashed" prefHeight="1" maxWidth="320"/>

            <!-- Tip Info -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="试用到期后功能将不可用" styleClass="tip-text"/>
                <HBox alignment="CENTER" spacing="4">
                    <Label text="请联系米多专员或拨打" styleClass="tip-text"/>
                    <Label text="15917372153" styleClass="contact-phone"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Footer：左边稍后提醒，右边立即激活 -->
        <HBox spacing="16" alignment="CENTER" styleClass="dialog-footer-center">
            <Button text="稍后提醒" styleClass="btn, btn-secondary"
                    onAction="#onLaterRemind" prefWidth="130"/>
            <Button text="立即激活" styleClass="btn, btn-primary"
                    onAction="#onActivateClick" prefWidth="130"/>
        </HBox>
    </VBox>

    <!-- 场景2：剩余1天（紧急样式） -->
    <VBox fx:id="sceneUrgent" visible="false" managed="false"
          styleClass="dialog-content" spacing="0" VBox.vgrow="ALWAYS">

        <!-- Header -->
        <HBox styleClass="dialog-header-flat" alignment="CENTER_LEFT">
            <Label text="试用即将到期" styleClass="dialog-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="closeButtonUrgent" text="×" styleClass="dialog-close-btn"
                    onAction="#onLaterRemind"/>
        </HBox>

        <!-- Body -->
        <VBox styleClass="dialog-body-center" spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">
            <!-- 闹钟图标 -->
            <VBox alignment="CENTER" spacing="0">
                <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                    <image>
                        <Image url="@/icons/提示.png"/>
                    </image>
                </ImageView>
            </VBox>
            
            <!-- 标题文字：试用期即将到期，剩余 X 天 -->
            <HBox alignment="CENTER" spacing="0">
                <Label text="试用期即将到期，剩余 " styleClass="expiring-title-text"/>
                <Label fx:id="countdownBadgeUrgent" text="1" styleClass="expiring-days-number-urgent"/>
                <Label text=" 天" styleClass="expiring-title-text"/>
            </HBox>

            <!-- Divider -->
            <HBox styleClass="divider-dashed" prefHeight="1" maxWidth="320"/>

            <!-- Tip Info with warning icon -->
            <VBox alignment="CENTER" spacing="8">
                <HBox alignment="CENTER" spacing="6">
                    <StackPane fx:id="urgentWarningIconPane" minWidth="14" minHeight="12" maxWidth="14" maxHeight="12"/>
                    <Label text="试用期明天到期！" styleClass="urgent-tip-text"/>
                </HBox>
                <HBox alignment="CENTER" spacing="4">
                    <Label text="请联系米多专员或拨打" styleClass="tip-text"/>
                    <Label text="15917372153" styleClass="contact-phone"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Footer：左边稍后提醒，右边立即激活 -->
        <HBox spacing="16" alignment="CENTER" styleClass="dialog-footer-center">
            <Button text="稍后提醒" styleClass="btn, btn-secondary"
                    onAction="#onLaterRemind" prefWidth="130"/>
            <Button text="立即激活" styleClass="btn, btn-primary"
                    onAction="#onActivateClick" prefWidth="130"/>
        </HBox>
    </VBox>

</VBox>
