<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.UnactivatedDialogController"
      styleClass="dialog-fullscreen" prefWidth="520">

    <!-- Dialog Header -->
    <HBox styleClass="dialog-header-flat" alignment="CENTER_LEFT">
        <Label text="产线采集软件" styleClass="dialog-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="closeButton" text="×" styleClass="dialog-close-btn" onAction="#onClose"/>
    </HBox>

    <!-- Dialog Body -->
    <VBox styleClass="dialog-body-center" spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">
        
        <!-- 警示图标 -->
        <VBox alignment="CENTER" spacing="0">
            <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                <image>
                    <Image url="@/icons/警示.png"/>
                </image>
            </ImageView>
        </VBox>
        
        <!-- 状态文字 -->
        <VBox alignment="CENTER" spacing="8">
            <Label text="软件未激活" styleClass="unactivated-title-text"/>
            <Label text="请联系米多专员获取许可证" styleClass="tip-text-gray"/>
        </VBox>

        <!-- 许可信息卡片 -->
        <VBox styleClass="info-card-flat" spacing="10" maxWidth="480">
            <VBox spacing="8" styleClass="reason-list-flat">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="·" styleClass="bullet-flat"/>
                    <Label text="试用许可：用于产线调试（每次15天）" styleClass="reason-item-flat"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="·" styleClass="bullet-flat"/>
                    <Label text="正式许可：用于正式生产" styleClass="reason-item-flat"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- 联系信息 -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="请联系米多专员或拨打" styleClass="tip-text-gray"/>
            <Label text="15917372153" styleClass="contact-phone"/>
        </HBox>
    </VBox>

    <!-- Dialog Footer -->
    <HBox spacing="16" alignment="CENTER" styleClass="dialog-footer-center">
        <Button fx:id="exitButton" text="退出" styleClass="btn, btn-secondary"
                onAction="#onExit" prefWidth="130"/>
        <Button fx:id="activateButton" text="激活" styleClass="btn, btn-primary"
                onAction="#onActivate" prefWidth="130"/>
    </HBox>

</VBox>
