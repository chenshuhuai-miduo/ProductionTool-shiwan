<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2RejectRecordsController"
      prefWidth="1200" prefHeight="700"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color:white; -fx-border-color:#D9E1EC; -fx-border-width:1; -fx-border-radius:12; -fx-background-radius:12;">

    <!-- 标题栏（对齐设计稿 4J8s2） -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT"
          style="-fx-background-color:#F5F7FA;
                 -fx-border-color:transparent transparent #E5E7EB transparent;
                 -fx-border-width:0 0 1 0;
                 -fx-padding:0 24;
                 -fx-min-height:56; -fx-pref-height:56;">
        <Label text="剔除记录"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1F2937; -fx-font-family:'Microsoft YaHei';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" onAction="#onClose" styleClass="sw2-dialog-title-close-btn"/>
    </HBox>

    <!-- 内容区 -->
    <VBox spacing="12" VBox.vgrow="ALWAYS" style="-fx-padding:24;">

        <!-- 筛选行 -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="caseCodeField" promptText="请输入箱码"
                       prefWidth="300" minWidth="300" maxWidth="300"
                       style="-fx-font-size:16px; -fx-background-color:#FFFFFF;
                              -fx-border-color:#D1D5DB; -fx-border-width:1;
                              -fx-border-radius:8; -fx-background-radius:8;
                              -fx-min-height:40; -fx-pref-height:40; -fx-padding:0 16;
                              -fx-font-family:'Microsoft YaHei';"/>
            <Button text="筛选" onAction="#onSearch"
                    style="-fx-min-width:80; -fx-pref-width:80; -fx-min-height:40; -fx-pref-height:40;
                           -fx-font-size:16px; -fx-font-weight:bold; -fx-background-color:#2563EB;
                           -fx-text-fill:white; -fx-background-radius:8; -fx-border-width:0;
                           -fx-cursor:hand; -fx-effect:null; -fx-font-family:'Microsoft YaHei';"/>
            <Button text="重置" onAction="#onReset"
                    style="-fx-min-width:80; -fx-pref-width:80; -fx-min-height:40; -fx-pref-height:40;
                           -fx-font-size:16px; -fx-font-weight:bold; -fx-background-color:#F3F4F6;
                           -fx-text-fill:#374151; -fx-background-radius:8;
                           -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-border-radius:8;
                           -fx-cursor:hand; -fx-effect:null; -fx-font-family:'Microsoft YaHei';"/>
        </HBox>

        <!-- 左右分栏：均分剩余宽度（约各占 50%，扣减间距与内边距后每栏约 568@1200 宽） -->
        <HBox spacing="16" VBox.vgrow="ALWAYS">

            <!-- 左侧：事件主表 + 分页 -->
            <VBox spacing="10" minWidth="280" prefWidth="568" HBox.hgrow="ALWAYS">

                <TableView fx:id="eventTable" VBox.vgrow="ALWAYS"
                           styleClass="sw2-wrap-table sw2-reject-master-table">
                    <columns>
                        <TableColumn fx:id="seqCol" text="序号" prefWidth="52" minWidth="52" maxWidth="52"/>
                        <TableColumn fx:id="caseCol" text="箱码" prefWidth="140" minWidth="80"/>
                        <TableColumn fx:id="timeCol" text="剔除时间" prefWidth="168" minWidth="150"/>
                        <TableColumn fx:id="summaryCol" text="原因摘要" prefWidth="200" minWidth="80"/>
                    </columns>
                    <placeholder>
                        <Label text="无匹配数据" styleClass="sw2-query-empty-hint"/>
                    </placeholder>
                </TableView>

                <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-min-height:48;">
                    <Label fx:id="totalLabel" text="共 0 条"
                           style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="每页"
                           style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                    <ComboBox fx:id="pageSizeCombo" prefWidth="90"
                              style="-fx-font-size:14px; -fx-pref-height:32; -fx-min-height:32;">
                        <items><FXCollections fx:factory="observableArrayList">
                            <String fx:value="10条"/>
                            <String fx:value="20条"/>
                            <String fx:value="50条"/>
                            <String fx:value="100条"/>
                        </FXCollections></items>
                        <value><String fx:value="20条"/></value>
                    </ComboBox>
                    <Button fx:id="prevBtn" text="上一页" onAction="#onPrevPage"
                            style="-fx-min-width:64; -fx-pref-width:64; -fx-min-height:32; -fx-pref-height:32;
                                   -fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#6B7280;
                                   -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:6;
                                   -fx-border-radius:6; -fx-cursor:hand; -fx-effect:null;"/>
                    <Label text="第"
                           style="-fx-font-size:14px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
                    <TextField fx:id="pageInputField" text="1" prefWidth="48"
                               onAction="#onPageInput"
                               styleClass="sw2-page-field-compact"
                               style="-fx-background-color:white; -fx-text-fill:#374151;
                                      -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-border-radius:6;
                                      -fx-background-radius:6; -fx-min-height:32; -fx-pref-height:32;
                                      -fx-alignment:CENTER; -fx-padding:0 8;"/>
                    <Label fx:id="totalPagesLabel" text="/ 1 页"
                           style="-fx-font-size:14px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
                    <Button fx:id="nextBtn" text="下一页" onAction="#onNextPage"
                            style="-fx-min-width:64; -fx-pref-width:64; -fx-min-height:32; -fx-pref-height:32;
                                   -fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#6B7280;
                                   -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:6;
                                   -fx-border-radius:6; -fx-cursor:hand; -fx-effect:null;"/>
                </HBox>
            </VBox>

            <!-- 右侧：概要卡片 + 留痕明细 -->
            <VBox fx:id="rightPane" spacing="12" minWidth="280" prefWidth="568" HBox.hgrow="ALWAYS">

                <VBox fx:id="detailEmptyPane" VBox.vgrow="ALWAYS" alignment="TOP_LEFT"
                      style="-fx-padding:8 0;">
                    <Label text="请点击左侧某次剔除记录查看明细" styleClass="sw2-query-empty-hint"/>
                </VBox>

                <VBox fx:id="detailPane" spacing="12" visible="false" managed="false" VBox.vgrow="ALWAYS">

                    <VBox spacing="10" styleClass="sw2-reject-summary-card">
                        <Label fx:id="sumCase" styleClass="sw2-reject-summary-line" wrapText="true"/>
                        <Label fx:id="sumTime" styleClass="sw2-reject-summary-line" wrapText="true"/>
                        <Label fx:id="sumOrder" styleClass="sw2-reject-summary-line" wrapText="true"/>
                        <Label fx:id="sumProductNo" styleClass="sw2-reject-summary-line" wrapText="true"/>
                        <Label fx:id="sumProductName" styleClass="sw2-reject-summary-line" wrapText="true"/>
                        <Label fx:id="sumTraceCount" styleClass="sw2-reject-summary-count" wrapText="true"/>
                    </VBox>

                    <Label text="留痕明细" styleClass="sw2-reject-detail-section-title"/>

                    <TableView fx:id="detailTable" VBox.vgrow="ALWAYS"
                               styleClass="sw2-wrap-table sw2-reject-detail-table">
                        <columns>
                            <TableColumn fx:id="dSeqCol" text="序号" minWidth="55" maxWidth="55"/>
                            <TableColumn fx:id="dLinkCol" text="关联码" prefWidth="220" minWidth="120"/>
                            <TableColumn fx:id="dProblemCol" text="问题码" prefWidth="120" minWidth="100" maxWidth="160"/>
                            <TableColumn fx:id="dReasonCol" text="剔除原因" prefWidth="200" minWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</VBox>
