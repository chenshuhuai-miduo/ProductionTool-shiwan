<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2RejectRecordsController"
      prefWidth="1200" prefHeight="700"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css"
      style="-fx-background-color:white; -fx-border-color:#D9E1EC; -fx-border-width:1;">

    <!-- 标题栏 -->
    <HBox fx:id="titleBar" alignment="CENTER_LEFT"
          style="-fx-background-color:#F5F7FA;
                 -fx-border-color:transparent transparent #E5E7EB transparent;
                 -fx-border-width:0 0 1 0;
                 -fx-padding:0 8 0 24;
                 -fx-min-height:56; -fx-pref-height:56;">
        <Label text="剔除记录"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1F2937; -fx-font-family:'Microsoft YaHei';"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="×" onAction="#onClose"
                style="-fx-background-color:transparent; -fx-text-fill:#9CA3AF; -fx-font-size:26px;
                       -fx-cursor:hand; -fx-min-width:44; -fx-min-height:44;
                       -fx-border-width:0; -fx-background-radius:6; -fx-effect:null; -fx-padding:0;"/>
    </HBox>

    <!-- 内容区 -->
    <VBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding:24;">

        <!-- 搜索行 -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="caseCodeField" promptText="请输入箱码"
                       prefWidth="300" minWidth="300" maxWidth="300"
                       style="-fx-font-size:16px; -fx-background-color:#FFFFFF;
                              -fx-border-color:#D1D5DB; -fx-border-width:1;
                              -fx-border-radius:8; -fx-background-radius:8;
                              -fx-min-height:40; -fx-pref-height:40; -fx-padding:0 16;
                              -fx-font-family:'Microsoft YaHei';"/>
            <Button text="筛选" onAction="#onSearch"
                    style="-fx-min-width:80; -fx-pref-width:80; -fx-min-height:40; -fx-pref-height:40;
                           -fx-font-size:16px; -fx-font-weight:bold; -fx-background-color:#2563EB;
                           -fx-text-fill:white; -fx-background-radius:8; -fx-border-width:0;
                           -fx-cursor:hand; -fx-effect:null; -fx-font-family:'Microsoft YaHei';"/>
            <Button text="重置" onAction="#onReset"
                    style="-fx-min-width:80; -fx-pref-width:80; -fx-min-height:40; -fx-pref-height:40;
                           -fx-font-size:16px; -fx-font-weight:bold; -fx-background-color:#F3F4F6;
                           -fx-text-fill:#374151; -fx-background-radius:8;
                           -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-border-radius:8;
                           -fx-cursor:hand; -fx-effect:null; -fx-font-family:'Microsoft YaHei';"/>
        </HBox>

        <!-- 左右分栏 -->
        <HBox spacing="16" VBox.vgrow="ALWAYS">

            <!-- 左侧表格区（固定宽度） -->
            <VBox spacing="8" prefWidth="800" minWidth="720" maxWidth="860"
                  style="-fx-background-color:#F9FAFB; -fx-border-color:#E5E7EB;
                         -fx-border-width:1; -fx-border-radius:8; -fx-background-radius:8;
                         -fx-padding:16;">

                <!-- 表格 -->
                <TableView fx:id="rejectTable" VBox.vgrow="ALWAYS"
                           styleClass="sw2-wrap-table">
                    <columns>
                        <TableColumn fx:id="seqCol"    text="序号"       prefWidth="60"  minWidth="60"  maxWidth="60"/>
                        <TableColumn fx:id="bottleCol" text="第一层(瓶码)" prefWidth="180" minWidth="180" maxWidth="180"/>
                        <TableColumn fx:id="boxCol"    text="第二层(盒码)" prefWidth="140" minWidth="140" maxWidth="140"/>
                        <TableColumn fx:id="caseCol"   text="第三层(箱码)" prefWidth="140" minWidth="140" maxWidth="140"/>
                        <TableColumn fx:id="reasonCol" text="剔除原因"    prefWidth="180"/>
                    </columns>
                    <placeholder>
                        <Label text="无匹配数据" styleClass="sw2-query-empty-hint"/>
                    </placeholder>
                </TableView>

                <!-- 分页 -->
                <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-min-height:40;">
                    <Label fx:id="totalLabel" text="共 0 条"
                           style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="每页"
                           style="-fx-font-size:14px; -fx-text-fill:#6B7280; -fx-font-family:'Microsoft YaHei';"/>
                    <ComboBox fx:id="pageSizeCombo" prefWidth="90"
                              style="-fx-font-size:14px; -fx-pref-height:32; -fx-min-height:32;">
                        <items><FXCollections fx:factory="observableArrayList">
                            <String fx:value="10条"/>
                            <String fx:value="20条"/>
                            <String fx:value="50条"/>
                            <String fx:value="100条"/>
                        </FXCollections></items>
                        <value><String fx:value="20条"/></value>
                    </ComboBox>
                    <Button fx:id="prevBtn" text="上一页" onAction="#onPrevPage"
                            style="-fx-min-width:64; -fx-pref-width:64; -fx-min-height:32; -fx-pref-height:32;
                                   -fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#6B7280;
                                   -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:6;
                                   -fx-border-radius:6; -fx-cursor:hand; -fx-effect:null;"/>
                    <Label text="第"
                           style="-fx-font-size:14px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
                    <TextField fx:id="pageInputField" text="1" prefWidth="48"
                               onAction="#onPageInput"
                               styleClass="sw2-page-field-compact"
                               style="-fx-background-color:white; -fx-text-fill:#374151;
                                      -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-border-radius:6;
                                      -fx-background-radius:6; -fx-min-height:32; -fx-pref-height:32;
                                      -fx-alignment:CENTER; -fx-padding:0 8;"/>
                    <Label fx:id="totalPagesLabel" text="/ 1 页"
                           style="-fx-font-size:14px; -fx-text-fill:#374151; -fx-font-family:'Microsoft YaHei';"/>
                    <Button fx:id="nextBtn" text="下一页" onAction="#onNextPage"
                            style="-fx-min-width:64; -fx-pref-width:64; -fx-min-height:32; -fx-pref-height:32;
                                   -fx-font-size:14px; -fx-background-color:white; -fx-text-fill:#6B7280;
                                   -fx-border-color:#D1D5DB; -fx-border-width:1; -fx-background-radius:6;
                                   -fx-border-radius:6; -fx-cursor:hand; -fx-effect:null;"/>
                </HBox>
            </VBox>

            <!-- 右侧详情卡片 -->
            <VBox HBox.hgrow="ALWAYS" minWidth="260" maxWidth="380"
                  style="-fx-background-color:white; -fx-border-color:#D9E1EC;
                         -fx-border-width:1; -fx-border-radius:12; -fx-background-radius:12;
                         -fx-padding:24;">
                <Label text="具体信息" styleClass="sw2-query-detail-main-title"
                       style="-fx-padding:0 0 8 0;"/>

                <!-- 空状态 -->
                <VBox fx:id="detailEmptyPane" VBox.vgrow="ALWAYS" alignment="CENTER">
                    <Label text="请点击左侧记录查看详细信息" styleClass="sw2-query-empty-hint"/>
                </VBox>

                <!-- 详情内容 -->
                <VBox fx:id="detailPane" spacing="10" visible="false" managed="false">
                    <Label text="剔除汇总" styleClass="sw2-query-detail-section-title"/>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="问题码：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detProblemCode" styleClass="sw2-dialog-detail-value-problem"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="箱码：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detCaseCode" styleClass="sw2-dialog-detail-value"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="剔除原因：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detReason" styleClass="sw2-dialog-detail-value"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="剔除时间：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detTime" styleClass="sw2-dialog-detail-value-muted"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <Label text="产品信息"
                           styleClass="sw2-query-detail-section-title sw2-dialog-detail-section-follow"/>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="产品编号：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detProductNo" styleClass="sw2-dialog-detail-value-muted"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="产品名称：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detProductName" styleClass="sw2-dialog-detail-value-muted"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="4" alignment="TOP_LEFT">
                        <Label text="生产单号：" styleClass="sw2-dialog-detail-label"/>
                        <Label fx:id="detOrderNo" styleClass="sw2-dialog-detail-value-muted"
                               prefWidth="0" minWidth="0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</VBox>
