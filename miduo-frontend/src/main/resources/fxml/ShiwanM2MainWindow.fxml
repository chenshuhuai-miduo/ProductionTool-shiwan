<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2MainController"
            prefWidth="1366" prefHeight="768"
            styleClass="shiwan-m2-root"
            stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <!-- ====================================================
         顶部菜单栏
         ==================================================== -->
    <top>
        <MenuBar styleClass="menu-bar">
            <Menu text="文件(F)">
                <MenuItem text="退出软件" onAction="#onExit"/>
            </Menu>
            <Menu text="配置">
                <MenuItem text="系统设置" onAction="#onSystemConfig"/>
                <MenuItem text="许可证信息" onAction="#onLicenseInfo"/>
            </Menu>
            <Menu text="数据">
                <MenuItem text="码包管理" onAction="#onCodePackage"/>
                <MenuItem text="数据查询" onAction="#onDataQuery"/>
                <MenuItem text="数据替换" onAction="#onDataReplace"/>
                <MenuItem text="取消关联" onAction="#onCancelAssociation"/>
                <MenuItem text="生产统计" onAction="#onProductionStats"/>
                <MenuItem text="数据上传" onAction="#onDataUpload"/>
                <MenuItem text="操作日志" onAction="#onOperationLog"/>
            </Menu>
            <Menu text="帮助(H)">
                <MenuItem text="操作帮助" onAction="#onHelp"/>
                <MenuItem text="关于系统" onAction="#onAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- ====================================================
         中央内容：TabPane + 内容
         ==================================================== -->
    <center>
        <VBox>
            <!-- TabPane (8 个 Tab) -->
            <TabPane fx:id="mainTabPane"
                     styleClass="shiwan-m2-tab-pane"
                     tabClosingPolicy="UNAVAILABLE"
                     VBox.vgrow="ALWAYS">

                <!-- ========== Tab 1: 数据采集 ========== -->
                <Tab text="数据采集" fx:id="dataCollectionTab">
                    <HBox styleClass="shiwan-m2-content-body" VBox.vgrow="ALWAYS">

                        <!-- ——— 左侧面板（320px）——— -->
                        <VBox prefWidth="320" minWidth="320" maxWidth="320" spacing="12">

                            <!-- 当前生产信息（含采集规格设置）-->
                            <VBox styleClass="shiwan-m2-card" spacing="10">

                                <!-- 标题 -->
                                <Label text="当前生产信息" styleClass="shiwan-m2-card-title"/>

                                <!-- 选择产品 -->
                                <Label text="选择产品" styleClass="shiwan-m2-form-label-small"/>
                                <ComboBox fx:id="productComboBox"
                                          promptText="-- 点击选择产品 --"
                                          styleClass="shiwan-m2-product-combo"
                                          maxWidth="Infinity"
                                          onAction="#onProductSelect"/>

                                <!-- 产品编号（初始隐藏，选中后显示） -->
                                <HBox fx:id="productCodeRow" spacing="8" alignment="CENTER_LEFT"
                                      managed="false" visible="false">
                                    <Label text="产品编号" styleClass="shiwan-m2-form-label-small"/>
                                    <Label fx:id="productCodeLabel" text="—"
                                           styleClass="shiwan-m2-product-code-label"/>
                                </HBox>

                                <!-- 生产单号 -->
                                <VBox spacing="4">
                                    <Label text="生产单号" styleClass="shiwan-m2-form-label-small"/>
                                    <TextField fx:id="orderNumField"
                                               text="20241201001"
                                               styleClass="shiwan-m2-order-input"
                                               maxWidth="Infinity"/>
                                </VBox>

                                <!-- 分割线 + 采集规格设置 -->
                                <Separator/>
                                <Label text="采集规格设置" styleClass="shiwan-m2-section-title"/>

                                <!-- 1垛 X 箱 -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="1垛" styleClass="shiwan-m2-spec-label"/>
                                    <TextField fx:id="casesPerPalletField"
                                               text="70"
                                               styleClass="shiwan-m2-spec-input"/>
                                    <Label text="箱" styleClass="shiwan-m2-spec-label"/>
                                </HBox>

                                <!-- 1箱 X 盒 -->
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="1箱" styleClass="shiwan-m2-spec-label"/>
                                    <TextField fx:id="boxesPerCaseField"
                                               text="4"
                                               styleClass="shiwan-m2-spec-input"/>
                                    <Label text="盒" styleClass="shiwan-m2-spec-label"/>
                                </HBox>
                            </VBox>

                            <!-- 实时上传数据区（填充剩余高度）-->
                            <VBox styleClass="shiwan-m2-card" VBox.vgrow="ALWAYS" spacing="8">
                                <Label text="实时上传数据区" styleClass="shiwan-m2-card-title"/>
                                <ListView fx:id="uploadDataList"
                                          VBox.vgrow="ALWAYS"
                                          styleClass="shiwan-m2-upload-list"/>
                            </VBox>
                        </VBox>

                        <!-- ——— 中间面板：三区 SplitPane（60%:20%:20%）——— -->
                        <SplitPane orientation="VERTICAL"
                                   dividerPositions="0.6, 0.8"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="shiwan-m2-split-pane">

                            <!-- 数据接收区（60%）-->
                            <VBox styleClass="shiwan-m2-area-card">
                                <HBox styleClass="shiwan-m2-area-header-bar">
                                    <Label text="数据接收区" styleClass="shiwan-m2-area-header-label"/>
                                    <Label text="（最新在上）" styleClass="shiwan-m2-area-header-hint"/>
                                </HBox>
                                <ListView fx:id="dataLogList"
                                          VBox.vgrow="ALWAYS"
                                          styleClass="shiwan-m2-log-list"/>
                            </VBox>

                            <!-- 操作日志（20%）-->
                            <VBox styleClass="shiwan-m2-area-card">
                                <HBox styleClass="shiwan-m2-area-header-bar">
                                    <Label text="操作日志" styleClass="shiwan-m2-area-header-label"/>
                                    <Label text="（最新在上）" styleClass="shiwan-m2-area-header-hint"/>
                                </HBox>
                                <ListView fx:id="opLogList"
                                          VBox.vgrow="ALWAYS"
                                          styleClass="shiwan-m2-log-list"/>
                            </VBox>

                            <!-- 报警信息（20%）-->
                            <VBox styleClass="shiwan-m2-area-card">
                                <HBox styleClass="shiwan-m2-area-header-bar">
                                    <Label text="报警信息" styleClass="shiwan-m2-area-header-label"/>
                                    <Label text="（最新在上）" styleClass="shiwan-m2-area-header-hint"/>
                                </HBox>
                                <ListView fx:id="alarmLogList"
                                          VBox.vgrow="ALWAYS"
                                          styleClass="shiwan-m2-log-list"/>
                            </VBox>
                        </SplitPane>

                        <!-- ——— 右侧面板（336px）——— -->
                        <VBox prefWidth="336" minWidth="336" maxWidth="336" spacing="12">

                            <!-- 单位实时统计（填充剩余高度）-->
                            <VBox styleClass="shiwan-m2-card" VBox.vgrow="ALWAYS" spacing="8">
                                <Label text="单位实时统计" styleClass="shiwan-m2-card-title"/>

                                <!-- 第1行：当前箱数 | 每垛箱数 -->
                                <HBox spacing="8" VBox.vgrow="ALWAYS">
                                    <VBox styleClass="shiwan-m2-stat-card"
                                          HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                                        <Label text="当前箱数" styleClass="shiwan-m2-stat-label"/>
                                        <Label fx:id="curCasesLabel" text="0"
                                               styleClass="shiwan-m2-stat-num-red"/>
                                    </VBox>
                                    <VBox styleClass="shiwan-m2-stat-card"
                                          HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                                        <Label text="每垛箱数" styleClass="shiwan-m2-stat-label"/>
                                        <Label fx:id="casesPerPalletDisplayLabel" text="70"
                                               styleClass="shiwan-m2-stat-num-blue"/>
                                    </VBox>
                                </HBox>

                                <!-- 第2行：当前盒数 | 每箱盒数 -->
                                <HBox spacing="8" VBox.vgrow="ALWAYS">
                                    <VBox styleClass="shiwan-m2-stat-card"
                                          HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                                        <Label text="当前盒数" styleClass="shiwan-m2-stat-label"/>
                                        <Label fx:id="curBoxesLabel" text="0"
                                               styleClass="shiwan-m2-stat-num-dark"/>
                                    </VBox>
                                    <VBox styleClass="shiwan-m2-stat-card"
                                          HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6">
                                        <Label text="每箱盒数" styleClass="shiwan-m2-stat-label"/>
                                        <Label fx:id="boxesPerCaseDisplayLabel" text="4"
                                               styleClass="shiwan-m2-stat-num-dark"/>
                                    </VBox>
                                </HBox>

                                <!-- 已生产垛数 -->
                                <HBox styleClass="shiwan-m2-stats-line" alignment="CENTER_LEFT">
                                    <Label text="已生产垛数"
                                           styleClass="shiwan-m2-stats-line-label"
                                           HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="palletCountLabel" text="0"
                                           styleClass="shiwan-m2-stats-line-val"/>
                                </HBox>

                                <!-- 总剔除数 -->
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label text="总剔除数"
                                           styleClass="shiwan-m2-stats-line-label"
                                           HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="rejectCountLabel" text="0"
                                           styleClass="shiwan-m2-reject-count"/>
                                </HBox>
                            </VBox>

                            <!-- 任务控制 -->
                            <VBox styleClass="shiwan-m2-card" spacing="12">

                                <!-- 标题行 + 问号帮助图标 -->
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <Label text="任务控制" styleClass="shiwan-m2-card-title"
                                           style="-fx-border-width: 0; -fx-padding: 0;"
                                           HBox.hgrow="ALWAYS"/>
                                    <Button text="?" styleClass="shiwan-m2-help-btn"
                                            onAction="#onTaskHelp"/>
                                </HBox>

                                <!-- 第1行：开始采集 | 无需采集码 -->
                                <HBox spacing="12">
                                    <Button fx:id="startCaptureBtn" text="开始采集"
                                            styleClass="shiwan-m2-ctrl-btn-primary"
                                            onAction="#onToggleCapture"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button text="无需采集码"
                                            styleClass="shiwan-m2-ctrl-btn-outline-blue"
                                            onAction="#onNoCodeNeeded"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                </HBox>

                                <!-- 第2行：关闭报警 | 强制满垛 -->
                                <HBox spacing="12">
                                    <Button text="关闭报警"
                                            styleClass="shiwan-m2-ctrl-btn-red"
                                            onAction="#onCloseAlarm"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button text="强制满垛"
                                            styleClass="shiwan-m2-ctrl-btn-green"
                                            onAction="#onForcePallet"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                </HBox>

                                <!-- 第3行：提取工单未成垛 | 收回剔除 -->
                                <HBox spacing="12">
                                    <Button text="提取工单未成垛"
                                            styleClass="shiwan-m2-ctrl-btn-primary"
                                            onAction="#onExtractUnfinished"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button text="收回剔除"
                                            styleClass="shiwan-m2-ctrl-btn-outline-blue"
                                            onAction="#onRetractReject"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                </HBox>

                                <!-- 第4行：剔除数清零（单独，左半） -->
                                <HBox spacing="12">
                                    <Button text="剔除数清零"
                                            styleClass="shiwan-m2-ctrl-btn-outline-red"
                                            onAction="#onResetRejectCount"
                                            HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </Tab>

                <!-- ========== Tab 2: 手工采集 ========== -->
                <Tab text="手工采集">
                    <fx:include source="ShiwanM2ManualTab.fxml"/>
                </Tab>

                <!-- ========== Tab 3: 数据查询 ========== -->
                <Tab text="数据查询">
                    <fx:include source="ShiwanM2QueryTab.fxml"/>
                </Tab>

                <!-- ========== Tab 4: 数据替换 ========== -->
                <Tab text="数据替换">
                    <fx:include source="ShiwanM2ReplaceTab.fxml"/>
                </Tab>

                <!-- ========== Tab 5: 生产统计 ========== -->
                <Tab text="生产统计">
                    <fx:include source="ShiwanM2StatsTab.fxml"/>
                </Tab>

                <!-- ========== Tab 6: 码包管理 ========== -->
                <Tab text="码包管理">
                    <fx:include source="ShiwanM2PackageTab.fxml"/>
                </Tab>

                <!-- ========== Tab 7: 取消关联 ========== -->
                <Tab text="取消关联">
                    <fx:include source="ShiwanM2CancelTab.fxml"/>
                </Tab>

                <!-- ========== Tab 8: 数据上传 ========== -->
                <Tab text="数据上传">
                    <fx:include source="ShiwanM2UploadTab.fxml"/>
                </Tab>

            </TabPane>
        </VBox>
    </center>

    <!-- ====================================================
         底部状态栏
         ==================================================== -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="0" bottom="0" left="16" right="16"/></padding>

            <!-- 激活状态 -->
            <Label fx:id="activationStatusLabel"
                   text="● 已激活"
                   styleClass="shiwan-m2-activation-badge"/>

            <!-- 运行状态 -->
            <Label fx:id="runningStatusLabel"
                   text="待机"
                   styleClass="shiwan-m2-running-label"
                   visible="false" managed="false"/>

            <!-- 弹性空白 -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- 系统名称 -->
            <Label text="盒箱垛关联采集系统 - 石湾2号机"
                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>

            <!-- 当前时间 -->
            <Label fx:id="currentTimeLabel"
                   text="2024-12-01  10:30:00"
                   style="-fx-font-size: 13px; -fx-text-fill: #374151;"/>
        </HBox>
    </bottom>

</BorderPane>
