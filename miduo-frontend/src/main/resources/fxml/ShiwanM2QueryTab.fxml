<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 数据查询 Tab -->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2QueryController"
      styleClass="sw2-tab-content" spacing="10"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <!-- 查询栏 -->
    <HBox styleClass="sw2-query-bar" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="queryInput"
                   promptText="请输入码信息或使用扫码枪扫描..."
                   styleClass="sw2-query-input"
                   HBox.hgrow="ALWAYS"
                   onKeyPressed="#onInputKeyPressed"/>
        <Button text="查询" styleClass="sw2-btn-primary"
                onAction="#onQuery"
                minHeight="40" prefHeight="40" style="-fx-padding:0 20px;"/>
        <Button text="清空" styleClass="sw2-btn-outline"
                onAction="#onClear"
                minHeight="40" prefHeight="40" style="-fx-padding:0 14px;"/>
        <Button text="?" styleClass="shiwan-m2-help-btn" onAction="#onHelp"/>
    </HBox>

    <!-- 主内容区：左右分栏 -->
    <HBox VBox.vgrow="ALWAYS" spacing="12">

        <!-- 左侧：码关联信息（填充剩余宽度）-->
        <VBox HBox.hgrow="ALWAYS" styleClass="sw2-result-panel" spacing="0">

            <!-- 标题行 + 条数 -->
            <HBox alignment="CENTER_LEFT" spacing="16" minHeight="48"
                  style="-fx-padding: 8px 16px 8px 16px; -fx-border-color: transparent transparent #E5E7EB transparent; -fx-border-width: 0 0 1px 0;">
                <Label text="码关联信息" styleClass="sw2-result-header" style="-fx-border-width:0;"/>
                <Label fx:id="countLabel" text="" styleClass="sw2-query-status-ok"/>
            </HBox>

            <!-- 空状态 -->
            <VBox fx:id="emptyPane" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="🔍" style="-fx-font-size:40px;"/>
                <Label text="请输入码进行查询"
                       style="-fx-font-size:16px; -fx-text-fill:#9CA3AF;"/>
            </VBox>

            <!-- 分层结果表格（序号 + 四层码）-->
            <TableView fx:id="resultTable" VBox.vgrow="ALWAYS"
                       styleClass="sw2-table" fixedCellSize="52"
                       visible="false" managed="false">
                <columns>
                    <TableColumn fx:id="colSeq" text="序号"
                                 prefWidth="60" minWidth="50" maxWidth="70"/>
                    <TableColumn fx:id="colL1"  text="第一层（瓶码）"
                                 prefWidth="210" minWidth="130"/>
                    <TableColumn fx:id="colL2"  text="第二层（盒码）"
                                 prefWidth="210" minWidth="130"/>
                    <TableColumn fx:id="colL3"  text="第三层（箱码）"
                                 prefWidth="160" minWidth="100"/>
                    <TableColumn fx:id="colL4"  text="第四层（垛码）"
                                 prefWidth="160" minWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="暂无数据" style="-fx-text-fill:#9CA3AF; -fx-font-size:16px;"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- 右侧：具体信息（固定宽度）-->
        <VBox prefWidth="300" minWidth="260" maxWidth="360"
              styleClass="sw2-result-panel" spacing="0">

            <HBox alignment="CENTER_LEFT" minHeight="48"
                  style="-fx-padding: 8px 16px 8px 16px; -fx-border-color: transparent transparent #E5E7EB transparent; -fx-border-width: 0 0 1px 0;">
                <Label text="具体信息" styleClass="sw2-result-header" style="-fx-border-width:0;"/>
            </HBox>

            <!-- 右侧空状态 -->
            <VBox fx:id="detailEmptyPane" VBox.vgrow="ALWAYS"
                  alignment="CENTER" spacing="8">
                <Label text="请点击左侧记录"
                       style="-fx-font-size:15px; -fx-text-fill:#9CA3AF;"/>
                <Label text="查看详细信息"
                       style="-fx-font-size:15px; -fx-text-fill:#9CA3AF;"/>
            </VBox>

            <!-- 详情内容（选中行后显示）-->
            <ScrollPane fx:id="detailScrollPane" VBox.vgrow="ALWAYS"
                        fitToWidth="true" visible="false" managed="false"
                        style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-width:0;">
                <VBox spacing="16" style="-fx-padding: 12px 16px 16px 16px;">

                    <!-- 码详细信息 -->
                    <VBox spacing="8">
                        <Label text="码详细信息"
                               style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <Separator/>
                        <GridPane hgap="8" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="72" maxWidth="72"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="瓶码" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="detBottle" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937; -fx-wrap-text:true;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label text="盒码" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="detBox" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937; -fx-wrap-text:true;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label text="箱码" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="detCase" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937; -fx-wrap-text:true;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            <Label text="垛码" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <Label fx:id="detPallet" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937; -fx-wrap-text:true;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            <Label text="采集时间" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <Label fx:id="detTime" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            <Label text="是否关联" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                            <Label fx:id="detLinked" text="—"
                                   style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#059669;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                        </GridPane>
                    </VBox>

                    <!-- 产品信息 -->
                    <VBox spacing="8">
                        <Label text="产品信息"
                               style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#374151;"/>
                        <Separator/>
                        <GridPane hgap="8" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="72" maxWidth="72"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="产品编号" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="detProductCode" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label text="产品名称" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="detProductName" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label text="生产单号" styleClass="sw2-field-label"
                                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="detOrderNo" text="—"
                                   style="-fx-font-size:15px; -fx-text-fill:#1F2937;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        </GridPane>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
