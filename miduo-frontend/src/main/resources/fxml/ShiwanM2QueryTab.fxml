<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 数据查询 Tab -->
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2QueryController"
           maxWidth="Infinity" maxHeight="Infinity"
           stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <VBox styleClass="sw2-tab-content" spacing="10" maxWidth="Infinity" maxHeight="Infinity">

    <!-- 查询栏 -->
    <HBox styleClass="sw2-query-bar" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="queryInput"
                   promptText="请输入码信息或使用扫码枪扫描..."
                   styleClass="sw2-query-input"
                   HBox.hgrow="ALWAYS"
                   onKeyPressed="#onInputKeyPressed"/>
        <Button fx:id="queryButton" text="查询" styleClass="sw2-btn-primary"
                onAction="#onQuery"
                minHeight="40" prefHeight="40" style="-fx-padding:0 20px;"/>
        <Button fx:id="clearButton" text="清空" styleClass="sw2-btn-outline"
                onAction="#onClear"
                minHeight="40" prefHeight="40" style="-fx-padding:0 14px;"/>
        <Button text="?" styleClass="shiwan-m2-help-btn" onAction="#onHelp"/>
        <!-- 右侧占位，与输入框同优先级平分剩余空间，使输入框约占 50% 宽 -->
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- 主内容区：左右分栏 -->
    <HBox VBox.vgrow="ALWAYS" spacing="12">

        <!-- 左侧：码关联信息（填充剩余宽度）-->
        <VBox HBox.hgrow="ALWAYS" styleClass="sw2-result-panel" spacing="0">

            <!-- 标题行 + 条数 -->
            <HBox alignment="CENTER_LEFT" spacing="16" minHeight="48"
                  style="-fx-padding: 8px 16px 8px 16px; -fx-border-color: transparent transparent #E5E7EB transparent; -fx-border-width: 0 0 1px 0;">
                <Label text="码关联信息" styleClass="sw2-result-header" style="-fx-border-width:0;"/>
                <Label fx:id="countLabel" text="" styleClass="sw2-query-status-ok"/>
            </HBox>

            <!-- 空状态 -->
            <VBox fx:id="emptyPane" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="🔍" styleClass="sw2-query-empty-icon"/>
                <Label text="请输入码进行查询" styleClass="sw2-query-empty-hint"/>
            </VBox>

            <!-- 分层结果表格（序号 + 四层码）-->
            <TableView fx:id="resultTable" VBox.vgrow="ALWAYS"
                       styleClass="sw2-table" fixedCellSize="52"
                       visible="false" managed="false">
                <columns>
                    <TableColumn fx:id="colSeq" text="序号"  prefWidth="36"/>
                    <TableColumn fx:id="colL1"  text="第一层（瓶码）" prefWidth="260"/>
                    <TableColumn fx:id="colL2"  text="第二层（盒码）" prefWidth="180"/>
                    <TableColumn fx:id="colL3"  text="第三层（箱码）" prefWidth="130"/>
                    <TableColumn fx:id="colL4"  text="第四层（垛码）" prefWidth="130"/>
                </columns>
                <placeholder>
                    <Label text="暂无数据" styleClass="sw2-query-empty-hint"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- 右侧：具体信息（固定宽度，与设计稿对齐 420px）-->
        <VBox prefWidth="420" minWidth="380"
              styleClass="sw2-result-panel" spacing="0">

            <!-- 右侧空状态 -->
            <VBox fx:id="detailEmptyPane" VBox.vgrow="ALWAYS"
                  alignment="CENTER" spacing="8">
                <Label text="请点击左侧记录" styleClass="sw2-query-empty-hint"/>
                <Label text="查看详细信息" styleClass="sw2-query-empty-hint"/>
            </VBox>

            <!-- 详情内容（选中行后显示）-->
            <ScrollPane fx:id="detailScrollPane" VBox.vgrow="ALWAYS"
                        fitToWidth="true" visible="false" managed="false"
                        style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-width:0;">
                <VBox spacing="16" style="-fx-padding: 24;">

                    <!-- 主标题 -->
                    <Label text="具体信息" styleClass="sw2-query-detail-main-title"/>

                    <!-- 码详细信息 -->
                    <Label text="码详细信息" styleClass="sw2-query-detail-section-title"/>

                    <GridPane hgap="8" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints minWidth="80" maxWidth="80"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="瓶码" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="detBottle" text="—" styleClass="sw2-query-detail-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="盒码" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="detBox" text="—" styleClass="sw2-query-detail-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="箱码" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="detCase" text="—" styleClass="sw2-query-detail-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Label text="垛码" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <Label fx:id="detPallet" text="—" styleClass="sw2-query-detail-value"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <Label text="采集时间" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <Label fx:id="detTime" text="—" styleClass="sw2-query-detail-value-muted"
                               GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <Label text="是否关联" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <Label fx:id="detLinked" text="—"
                               styleClass="sw2-query-detail-value-muted"
                               GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    </GridPane>

                    <!-- 产品信息 -->
                    <Label text="产品信息" styleClass="sw2-query-detail-section-title"/>

                    <GridPane hgap="8" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints minWidth="80" maxWidth="80"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <Label text="产品编号" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="detProductCode" text="—" styleClass="sw2-query-detail-value-muted"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="产品名称" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="detProductName" text="—" styleClass="sw2-query-detail-value-muted"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="生产单号" styleClass="sw2-query-detail-key"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="detOrderNo" text="—" styleClass="sw2-query-detail-value-muted"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>

                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
    </VBox>

    <StackPane fx:id="queryLoadingOverlay" visible="false" managed="false"
               styleClass="sw2-loading-overlay" maxWidth="Infinity" maxHeight="Infinity"
               pickOnBounds="true">
        <VBox alignment="CENTER" spacing="12">
            <ProgressIndicator styleClass="sw2-loading-spinner"/>
            <Label text="正在查询，请稍候…"/>
        </VBox>
    </StackPane>
</StackPane>
