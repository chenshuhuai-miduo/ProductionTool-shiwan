<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- 数据查询 Tab -->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.miduo.cloud.frontend.controller.ShiwanM2QueryController"
      styleClass="sw2-tab-content" spacing="10"
      stylesheets="@../css/base-styles.css,@../css/shiwan-m2-styles.css">

    <!-- 查询栏 -->
    <HBox styleClass="sw2-query-bar" spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="queryInput"
                   promptText="请输入码信息或使用扫码枪扫描..."
                   styleClass="sw2-query-input"
                   HBox.hgrow="ALWAYS"
                   onKeyPressed="#onInputKeyPressed"/>
        <Button text="正向查询" styleClass="sw2-btn-primary"
                onAction="#onForwardQuery"
                minHeight="40" prefHeight="40" style="-fx-padding:0 18px;"/>
        <Button text="反向查询" styleClass="sw2-btn-green"
                onAction="#onReverseQuery"
                minHeight="40" prefHeight="40" style="-fx-padding:0 18px;"/>
        <Button text="清空" styleClass="sw2-btn-outline"
                onAction="#onClear"
                minHeight="40" prefHeight="40" style="-fx-padding:0 14px;"/>
        <Button text="?" styleClass="shiwan-m2-help-btn" onAction="#onHelp"/>
        <Label fx:id="queryStatusLabel" text="未查询" styleClass="sw2-query-status-idle"/>
    </HBox>

    <!-- 结果区（StackPane：默认空状态/查询结果切换）-->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- 空状态（默认显示）-->
        <VBox fx:id="emptyPane" alignment="CENTER" spacing="12">
            <Label text="🔍" style="-fx-font-size:48px;"/>
            <Label text="请输入码进行正向或反向查询" style="-fx-font-size:15px; -fx-text-fill:#9CA3AF;"/>
        </VBox>

        <!-- 正向查询结果（code → 下级）-->
        <VBox fx:id="forwardResultPane" visible="false" managed="false" spacing="10">
            <!-- 查询码信息 -->
            <HBox styleClass="sw2-query-bar" spacing="12" alignment="CENTER_LEFT">
                <Label text="查询码信息：" styleClass="sw2-filter-label"/>
                <Label text="码值：" styleClass="sw2-filter-label"/>
                <Label fx:id="fwdCodeValue" text="" styleClass="sw2-code-value-label"
                       style="-fx-text-fill:#2563EB;"/>
                <Label text="层级：" styleClass="sw2-filter-label"/>
                <Label fx:id="fwdCodeType" text="" styleClass="sw2-badge-blue"/>
                <Label text="采集时间：" styleClass="sw2-filter-label"/>
                <Label fx:id="fwdCodeTime" text="" styleClass="sw2-filter-label"
                       style="-fx-font-weight: normal;"/>
            </HBox>
            <!-- 正向结果表格 -->
            <VBox styleClass="sw2-result-panel" VBox.vgrow="ALWAYS">
                <Label fx:id="fwdResultTitle" text="正向查询结果（直接下级）："
                       styleClass="sw2-result-header"/>
                <Label fx:id="fwdCountLabel" text="" style="-fx-font-size:13px; -fx-text-fill:#6B7280; -fx-padding:4px 16px;"/>
                <TableView fx:id="fwdTable" VBox.vgrow="ALWAYS" styleClass="sw2-table">
                    <columns>
                        <TableColumn fx:id="fwdColSeq"  text="序号"   prefWidth="60"  minWidth="50"/>
                        <TableColumn fx:id="fwdColCode" text="码值"   prefWidth="200" minWidth="150"/>
                        <TableColumn fx:id="fwdColTime" text="采集时间" prefWidth="180" minWidth="150"/>
                    </columns>
                    <placeholder><Label text="暂无数据" style="-fx-text-fill:#9CA3AF;"/></placeholder>
                </TableView>
            </VBox>
        </VBox>

        <!-- 反向查询结果（code → 上级路径 + 同级）-->
        <VBox fx:id="reverseResultPane" visible="false" managed="false" spacing="10">
            <!-- 查询码信息 -->
            <HBox styleClass="sw2-query-bar" spacing="12" alignment="CENTER_LEFT">
                <Label text="查询码信息：" styleClass="sw2-filter-label"/>
                <Label text="码值：" styleClass="sw2-filter-label"/>
                <Label fx:id="revCodeValue" text="" styleClass="sw2-code-value-label"
                       style="-fx-text-fill:#2563EB;"/>
                <Label text="层级：" styleClass="sw2-filter-label"/>
                <Label fx:id="revCodeType" text="" styleClass="sw2-badge-blue"/>
                <Label text="采集时间：" styleClass="sw2-filter-label"/>
                <Label fx:id="revCodeTime" text="" styleClass="sw2-filter-label"
                       style="-fx-font-weight: normal;"/>
            </HBox>

            <!-- 上级关联路径（动态生成）-->
            <VBox styleClass="sw2-result-panel">
                <Label text="上级关联路径：" styleClass="sw2-result-header"/>
                <HBox fx:id="chainBox" spacing="8" alignment="CENTER_LEFT"
                      style="-fx-padding:16px; -fx-background-color:#F3F4F6; -fx-background-radius:0 0 10px 10px;">
                    <Label text="—" style="-fx-text-fill:#9CA3AF; -fx-font-size:14px;"/>
                </HBox>
            </VBox>

            <!-- 同级数据表格 -->
            <VBox styleClass="sw2-result-panel" VBox.vgrow="ALWAYS">
                <Label fx:id="siblingTitle" text="同级数据：" styleClass="sw2-result-header"/>
                <TableView fx:id="siblingTable" VBox.vgrow="ALWAYS" styleClass="sw2-table">
                    <columns>
                        <TableColumn fx:id="sibColCode" text="码值"   prefWidth="220" minWidth="160"/>
                        <TableColumn fx:id="sibColTime" text="采集时间" prefWidth="180" minWidth="150"/>
                    </columns>
                    <placeholder><Label text="暂无同级数据" style="-fx-text-fill:#9CA3AF;"/></placeholder>
                </TableView>
            </VBox>
        </VBox>

    </StackPane>
</VBox>
